---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Profile">
  <h1>Manage Profile</h1>
  
  <form id="profile-form" style="display: flex; flex-direction: column; gap: 1rem; max-width: 600px;">
    <div>
      <label for="full-name" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Full Name *</label>
      <input 
        type="text" 
        id="full-name" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="title" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Title *</label>
      <input 
        type="text" 
        id="title" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="about" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">About *</label>
      <textarea 
        id="about" 
        required
        rows="3"
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      ></textarea>
    </div>
    
    <div>
      <label for="summary" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Summary *</label>
      <textarea 
        id="summary" 
        required
        rows="5"
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      ></textarea>
    </div>
    
    <div>
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email *</label>
      <input 
        type="email" 
        id="email" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="tel" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Phone</label>
      <input 
        type="tel" 
        id="tel" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="location" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Location *</label>
      <input 
        type="text" 
        id="location" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="location-link" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Location Link</label>
      <input 
        type="url" 
        id="location-link" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div style="display: flex; gap: 2rem; align-items: flex-start; border: 1px solid #e5e7eb; padding: 1.5rem; border-radius: 0.5rem; background-color: #f9fafb;">
      <div style="flex-shrink: 0;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Profile Photo</label>
        <div id="avatar-preview-container" style="width: 120px; height: 120px; border-radius: 0.75rem; border: 2px dashed #d1d5db; display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: #fff;">
          <img id="avatar-preview" src="" style="width: 100%; height: 100%; object-cover: cover; display: none;" />
          <div id="avatar-placeholder" style="color: #9ca3af;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 40px; height: 40px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
        </div>
      </div>
      <div style="flex-grow: 1;">
        <label for="avatar-file" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Upload New Photo</label>
        <input 
          type="file" 
          id="avatar-file" 
          accept="image/*"
          style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none; background-color: #fff;" 
        />
        <p style="font-size: 0.75rem; color: #6b7280; margin-top: 0.5rem;">JPG, PNG or WebP. Max 2MB.</p>
        <input type="hidden" id="avatar-url" />
      </div>
    </div>
    
    <div>
      <label for="resume-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Resume URL</label>
      <input 
        type="url" 
        id="resume-url" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="linkedin-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">LinkedIn URL</label>
      <input 
        type="url" 
        id="linkedin-url" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="instagram-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Instagram URL</label>
      <input 
        type="url" 
        id="instagram-url" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="website-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Personal Website URL</label>
      <input 
        type="url" 
        id="website-url" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <button 
      type="submit"
      style="padding: 0.75rem 1.5rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer; margin-top: 1rem;"
    >
      Save Profile
    </button>
  </form>
</AdminLayout>

<script is:inline>
  // Load profile on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadProfile();
  });
  
  // Load profile from API
  async function loadProfile() {
    try {
      const profile = await api('GET', '/api/profile');
      
      document.getElementById('full-name').value = profile.full_name || '';
      document.getElementById('title').value = profile.title || '';
      document.getElementById('about').value = profile.about || '';
      document.getElementById('summary').value = profile.summary || '';
      document.getElementById('email').value = profile.email || '';
      document.getElementById('tel').value = profile.tel || '';
      document.getElementById('location').value = profile.location || '';
      document.getElementById('location-link').value = profile.location_link || '';
      document.getElementById('avatar-url').value = profile.avatar_url || '';
      document.getElementById('resume-url').value = profile.resume_url || '';
      document.getElementById('linkedin-url').value = profile.linkedin_url || '';
      document.getElementById('instagram-url').value = profile.instagram_url || '';
      document.getElementById('website-url').value = profile.website_url || '';

      // Update avatar preview
      updateAvatarPreview(profile.avatar_url);
    } catch (error) {
      console.error('Error loading profile:', error);
      showToast('Failed to load profile', 'error');
    }
  }

  function updateAvatarPreview(url) {
    const preview = document.getElementById('avatar-preview');
    const placeholder = document.getElementById('avatar-placeholder');
    if (url) {
      preview.src = url;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
    } else {
      preview.style.display = 'none';
      placeholder.style.display = 'block';
    }
  }

  // Handle avatar file selection preview
  document.getElementById('avatar-file').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        updateAvatarPreview(e.target.result);
      };
      reader.readAsDataURL(file);
    }
  });
  
  // Handle form submission
  document.getElementById('profile-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalBtnText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    try {
      let avatarUrl = document.getElementById('avatar-url').value;
      const avatarFile = document.getElementById('avatar-file').files[0];

      // 1. If a new file is selected, upload it to R2 first
      if (avatarFile) {
        showToast('Uploading profile photo...');
        try {
          avatarUrl = await uploadFile(avatarFile, 'profile');
          document.getElementById('avatar-url').value = avatarUrl;
        } catch (uploadError) {
          throw new Error('Failed to upload photo: ' + uploadError.message);
        }
      }
      
      // 2. Save the rest of the profile data
      const formData = {
        full_name: document.getElementById('full-name').value,
        title: document.getElementById('title').value,
        about: document.getElementById('about').value,
        summary: document.getElementById('summary').value,
        email: document.getElementById('email').value,
        tel: document.getElementById('tel').value,
        location: document.getElementById('location').value,
        location_link: document.getElementById('location-link').value,
        avatar_url: avatarUrl,
        resume_url: document.getElementById('resume-url').value,
        linkedin_url: document.getElementById('linkedin-url').value,
        instagram_url: document.getElementById('instagram-url').value,
        website_url: document.getElementById('website-url').value
      };
    
      const response = await api('PUT', '/api/admin/profile', formData);
      
      if (response.success) {
        showToast('Profile updated successfully!', 'success');
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
        } catch (deployError) {
          console.error('Deploy failed:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to update profile', 'error');
      }
    } catch (error) {
      console.error('Error saving profile:', error);
      showToast(error.message || 'Failed to update profile', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });
</script>