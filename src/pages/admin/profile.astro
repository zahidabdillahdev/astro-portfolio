---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Profile">
  <h1>Manage Profile</h1>
  
  <form id="profile-form" style="display: flex; flex-direction: column; gap: 1rem; max-width: 600px;">
    <div>
      <label for="full-name" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Full Name *</label>
      <input 
        type="text" 
        id="full-name" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="title" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Title *</label>
      <input 
        type="text" 
        id="title" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="about" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">About *</label>
      <textarea 
        id="about" 
        required
        rows="5"
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      ></textarea>
    </div>
    
    <div>
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email *</label>
      <input 
        type="email" 
        id="email" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="tel" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Phone</label>
      <input 
        type="tel" 
        id="tel" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div>
      <label for="location" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Location *</label>
      <input 
        type="text" 
        id="location" 
        required
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <div style="display: flex; gap: 2rem; align-items: flex-start; border: 1px solid var(--color-border); padding: 1.25rem; border-radius: 0.5rem; background-color: var(--color-bg);">
      <div style="flex-shrink: 0;">
        <label style="margin-bottom: 0.5rem;">Profile Photo</label>
        <div style="position: relative; width: 100px; height: 100px;">
          <div id="avatar-preview-container" style="width: 100px; height: 100px; border-radius: 0.75rem; border: 2px dashed #d4d4d8; display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: #fff;">
            <img id="avatar-preview" src="" style="width: 100%; height: 100%; object-fit: cover; display: none;" />
            <div id="avatar-placeholder" style="color: #a1a1aa;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 36px; height: 36px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
          </div>
          <button
            type="button"
            id="avatar-remove-btn"
            onclick="removeAvatar()"
            style="display: none; position: absolute; top: -8px; right: -8px; width: 22px; height: 22px; border-radius: 50%; background-color: #ef4444; color: #fff; border: 2px solid #fff; cursor: pointer; font-size: 0.7rem; line-height: 1; align-items: center; justify-content: center;"
            title="Remove photo"
          >✕</button>
        </div>
      </div>
      <div style="flex-grow: 1;">
        <label for="avatar-file">Upload New Photo</label>
        <input type="file" id="avatar-file" accept="image/*" />
        <p style="font-size: 0.75rem; color: var(--color-muted); margin-top: 0.375rem;">JPG, PNG or WebP. Max 10MB. Auto-compressed.</p>
        <input type="hidden" id="avatar-url" />
      </div>
    </div>
    
    <div style="border: 1px solid var(--color-border); padding: 1.25rem; border-radius: 0.5rem; background-color: var(--color-bg);">
      <label for="resume-file">Resume / CV Document</label>
      <input type="file" id="resume-file" accept=".pdf,.doc,.docx" style="margin-bottom: 0.375rem;" />
      <p style="font-size: 0.75rem; color: var(--color-muted); margin: 0 0 0.5rem;">PDF, DOC, or DOCX. Max 5MB.</p>
      <input type="hidden" id="resume-url" />
      <div id="current-resume-link" style="font-size: 0.8125rem; display: flex; align-items: center; gap: 0.5rem;"></div>
    </div>
    
    <div>
      <label for="linkedin-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">LinkedIn URL</label>
      <input 
        type="url" 
        id="linkedin-url" 
        style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
      />
    </div>
    
    <button 
      type="submit"
      style="padding: 0.75rem 1.5rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer; margin-top: 1rem;"
    >
      Save Profile
    </button>
  </form>
</AdminLayout>

<script is:inline>
  // Load profile on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadProfile();
  });
  
  // Load profile from API
  async function loadProfile() {
    try {
      const profile = await api('GET', '/api/profile');
      
      document.getElementById('full-name').value = profile.full_name || '';
      document.getElementById('title').value = profile.title || '';
      document.getElementById('about').value = profile.about || profile.summary || '';
      document.getElementById('email').value = profile.email || '';
      document.getElementById('tel').value = profile.tel || '';
      document.getElementById('location').value = profile.location || '';
      document.getElementById('avatar-url').value = profile.avatar_url || '';
      document.getElementById('resume-url').value = profile.resume_url || '';
      document.getElementById('linkedin-url').value = profile.linkedin_url || '';

      // Update avatar preview
      updateAvatarPreview(profile.avatar_url);

      // Update resume link
      updateResumeDisplay(profile.resume_url);
    } catch (error) {
      console.error('Error loading profile:', error);
    }
  }

  function updateResumeDisplay(url) {
    const linkContainer = document.getElementById('current-resume-link');
    if (url) {
      const fileName = url.split('/').pop();
      linkContainer.innerHTML = `
        <a href="${url}" target="_blank" style="color: #3b82f6; text-decoration: underline; font-size: 0.8125rem;">${fileName}</a>
        <button type="button" onclick="removeResume()" style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 0.75rem; padding: 0.125rem 0.375rem; border-radius: 0.25rem; border: 1px solid #fecaca;">✕ Remove</button>
      `;
    } else {
      linkContainer.innerHTML = '<span style="color: var(--color-muted); font-size: 0.8125rem;">No resume uploaded yet.</span>';
    }
  }

  function updateAvatarPreview(url) {
    const preview = document.getElementById('avatar-preview');
    const placeholder = document.getElementById('avatar-placeholder');
    const removeBtn = document.getElementById('avatar-remove-btn');
    if (url) {
      preview.src = url;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
      removeBtn.style.display = 'flex';
    } else {
      preview.style.display = 'none';
      placeholder.style.display = 'block';
      removeBtn.style.display = 'none';
    }
  }

  async function removeAvatar() {
    if (!confirm('Remove profile photo?')) return;
    document.getElementById('avatar-url').value = '';
    document.getElementById('avatar-file').value = '';
    updateAvatarPreview('');
    await api('PUT', '/api/admin/profile', { avatar_url: '' });
    showToast('Photo removed', 'success');
    try { await triggerDeploy(); } catch(e) {}
  }

  async function removeResume() {
    if (!confirm('Remove resume file?')) return;
    document.getElementById('resume-url').value = '';
    document.getElementById('resume-file').value = '';
    updateResumeDisplay('');
    await api('PUT', '/api/admin/profile', { resume_url: '' });
    showToast('Resume removed', 'success');
    try { await triggerDeploy(); } catch(e) {}
  }

  // Handle avatar file selection preview
  document.getElementById('avatar-file').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        updateAvatarPreview(e.target.result);
      };
      reader.readAsDataURL(file);
    }
  });

  // Handle resume file selection feedback
  document.getElementById('resume-file').addEventListener('change', function(e) {
    const file = e.target.files[0];
    const linkContainer = document.getElementById('current-resume-link');
    if (file) {
      linkContainer.innerHTML = `<span style="color: var(--color-muted); font-size: 0.8125rem;">Selected: ${file.name}</span>`;
    }
  });
  
  // Handle form submission
  document.getElementById('profile-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalBtnText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    try {
      let avatarUrl = document.getElementById('avatar-url').value;
      const avatarFile = document.getElementById('avatar-file').files[0];
      
      let resumeUrl = document.getElementById('resume-url').value;
      const resumeFile = document.getElementById('resume-file').files[0];

      // 1. If a new photo is selected, upload it to R2 first
      if (avatarFile) {
        showToast('Uploading profile photo...');
        try {
          avatarUrl = await uploadFile(avatarFile, 'profile');
          document.getElementById('avatar-url').value = avatarUrl;
        } catch (uploadError) {
          throw new Error('Failed to upload photo: ' + uploadError.message);
        }
      }

      // 2. If a new resume is selected, upload it to R2
      if (resumeFile) {
        showToast('Uploading resume...');
        try {
          resumeUrl = await uploadFile(resumeFile, 'documents');
          document.getElementById('resume-url').value = resumeUrl;
        } catch (uploadError) {
          throw new Error('Failed to upload resume: ' + uploadError.message);
        }
      }
      
      // 3. Save the rest of the profile data
      const aboutValue = document.getElementById('about').value;

      const formData = {
        full_name: document.getElementById('full-name').value,
        title: document.getElementById('title').value,
        about: aboutValue,
        summary: aboutValue,
        email: document.getElementById('email').value,
        tel: document.getElementById('tel').value,
        location: document.getElementById('location').value,
        avatar_url: avatarUrl,
        resume_url: resumeUrl,
        linkedin_url: document.getElementById('linkedin-url').value
      };
    
      const response = await api('PUT', '/api/admin/profile', formData);
      
      if (response.success) {
        showToast('Profile updated successfully!', 'success');
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
        } catch (deployError) {
          console.error('Deploy failed:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to update profile', 'error');
      }
    } catch (error) {
      console.error('Error saving profile:', error);
      showToast(error.message || 'Failed to update profile', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });
</script>
