---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Education">
  <h1>Manage Education</h1>
  
  <button 
    onclick="openModal(null)"
    style="background-color: #000; color: #fff; padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; cursor: pointer; margin-bottom: 1rem;"
  >
    + Add New Education
  </button>
  
  <div class="table-container" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb;">
      <thead>
        <tr style="background-color: #f9fafb;">
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">School</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Degree</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Years</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody id="education-table-body">
        <!-- Table rows will be populated by JavaScript -->
      </tbody>
    </table>
  </div>
  
  <!-- Modal -->
  <div id="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000; padding: 1rem; overflow-y: auto; align-items: flex-start; justify-content: center;">
    <div style="background-color: #fff; width: 100%; max-width: 600px; border-radius: 0.5rem; padding: 1.5rem; position: relative; margin-top: 2rem; margin-bottom: 2rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 id="modal-title" style="margin: 0;">Add New Education</h2>
        <button onclick="closeModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #6b7280; padding: 0.5rem;">&times;</button>
      </div>
      
      <form id="education-form" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" id="education-id" />
        
        <div>
          <label for="school" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">School *</label>
          <input 
            type="text" 
            id="school" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="degree" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Degree *</label>
          <input 
            type="text" 
            id="degree" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="start-year" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Start Year *</label>
          <input 
            type="text" 
            id="start-year" 
            placeholder="e.g. 2018"
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="end-year" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">End Year</label>
          <input 
            type="text" 
            id="end-year" 
            placeholder="e.g. 2022 or Present"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="order-index" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Order Index</label>
          <input 
            type="number" 
            id="order-index" 
            value="0"
            style="width: 100px; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
          <button 
            type="button" 
            onclick="closeModal()"
            style="padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; cursor: pointer; background-color: #f9fafb;"
          >
            Cancel
          </button>
          <button 
            type="submit"
            style="padding: 0.5rem 1rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer;"
          >
            Save Education
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Load education on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadEducation();
  });
  
  // Load education from API
  async function loadEducation() {
    try {
      const education = await api('GET', '/api/education');
      renderEducationTable(education);
    } catch (error) {
      console.error('Error loading education:', error);
    }
  }
  
  // Render education in the table
  function renderEducationTable(education) {
    const tbody = document.getElementById('education-table-body');
    tbody.innerHTML = '';
    
    education.forEach(edu => {
      const years = `${edu.start_year} - ${edu.end_year || 'Present'}`;
      
      const row = document.createElement('tr');
      row.innerHTML = `
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${edu.school}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${edu.degree}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${years}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">
          <button onclick="openModal(${edu.id})" style="margin-right: 0.5rem; padding: 0.25rem 0.5rem; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Edit</button>
          <button onclick="deleteEducation(${edu.id})" style="padding: 0.25rem 0.5rem; background-color: #fee2e2; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Delete</button>
        </td>
      `;
      tbody.appendChild(row);
    });
  }
  
  // Open modal for adding/editing education
  function openModal(eduId) {
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modal-title');
    const form = document.getElementById('education-form');
    
    // Reset form
    form.reset();
    document.getElementById('education-id').value = '';
    
    if (eduId) {
      // Editing existing education
      modalTitle.textContent = 'Edit Education';
      
      // Find the education and populate the form
      api('GET', '/api/education').then(edu => {
        const eduItem = edu.find(e => e.id === eduId);
        if (eduItem) {
          document.getElementById('education-id').value = eduItem.id;
          document.getElementById('school').value = eduItem.school;
          document.getElementById('degree').value = eduItem.degree;
          document.getElementById('start-year').value = eduItem.start_year || '';
          document.getElementById('end-year').value = eduItem.end_year || '';
          document.getElementById('order-index').value = eduItem.order_index || 0;
        }
      });
    } else {
      // Adding new education
      modalTitle.textContent = 'Add New Education';
    }
    
    modal.style.display = 'flex';
  }
  
  // Close modal
  function closeModal() {
    document.getElementById('modal').style.display = 'none';
  }
  
  // Handle form submission
  document.getElementById('education-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const eduId = document.getElementById('education-id').value;
    const formData = {
      id: eduId ? parseInt(eduId) : undefined,
      school: document.getElementById('school').value,
      degree: document.getElementById('degree').value,
      startYear: document.getElementById('start-year').value,
      endYear: document.getElementById('end-year').value,
      orderIndex: parseInt(document.getElementById('order-index').value) || 0
    };
    
    try {
      let response;
      if (eduId) {
        // Update existing education
        response = await api('PUT', `/api/admin/education/${eduId}`, formData);
      } else {
        // Create new education
        response = await api('POST', '/api/admin/education', formData);
      }
      
      if (response.success || response.id) {
        showToast(eduId ? 'Education updated!' : 'Education created!', 'success');
        closeModal();
        loadEducation(); // Reload the table
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
        } catch (deployError) {
          console.error('Deploy failed:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to save education', 'error');
      }
    } catch (error) {
      console.error('Error saving education:', error);
      showToast('Failed to save education', 'error');
    }
  });
  
  // Delete education
  async function deleteEducation(eduId) {
    if (!confirm('Are you sure you want to delete this education?')) {
      return;
    }
    
    try {
      const response = await api('DELETE', `/api/admin/education/${eduId}`);
      
      if (response.success) {
        showToast('Education deleted!', 'success');
        loadEducation(); // Reload the table
        
        // Trigger deploy after deletion
        try {
          await triggerDeploy();
        } catch (deployError) {
          console.error('Deploy failed:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to delete education', 'error');
      }
    } catch (error) {
      console.error('Error deleting education:', error);
      showToast('Failed to delete education', 'error');
    }
  }
</script>