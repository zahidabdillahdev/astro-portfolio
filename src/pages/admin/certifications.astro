---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Certifications">
  <h1>Manage Certifications</h1>
  
  <button 
    onclick="openModal(null)"
    style="background-color: #000; color: #fff; padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; cursor: pointer; margin-bottom: 1rem;"
  >
    + Add New Certification
  </button>
  
  <div class="table-container" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb;">
      <thead>
        <tr style="background-color: #f9fafb;">
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Title</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Issuer</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Issue Date</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody id="certifications-table-body">
        <!-- Table rows will be populated by JavaScript -->
      </tbody>
    </table>
  </div>
  
  <!-- Modal -->
  <div id="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000; padding: 1rem; overflow-y: auto; align-items: flex-start; justify-content: center;">
    <div style="background-color: #fff; width: 100%; max-width: 600px; border-radius: 0.5rem; padding: 1.5rem; position: relative; margin-top: 2rem; margin-bottom: 2rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 id="modal-title" style="margin: 0;">Add New Certification</h2>
        <button onclick="closeModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #6b7280; padding: 0.5rem;">&times;</button>
      </div>
      
      <form id="certification-form" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" id="certification-id" />
        
        <div>
          <label for="title" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Title *</label>
          <input 
            type="text" 
            id="title" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="issuer" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Issuer *</label>
          <input 
            type="text" 
            id="issuer" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="issue-date" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Issue Date</label>
          <input 
            type="date" 
            id="issue-date" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="expiry-date" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Expiry Date</label>
          <input 
            type="date" 
            id="expiry-date" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="credential-id" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Credential ID</label>
          <input 
            type="text" 
            id="credential-id" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="credential-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Credential URL</label>
          <input 
            type="text" 
            id="credential-url" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>

        <div>
          <label for="certificate-file" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Certificate PDF</label>
          <input
            type="file"
            id="certificate-file"
            accept=".pdf,application/pdf"
            style="display: block; margin-bottom: 0.375rem;"
          />
          <input type="hidden" id="certificate-url" />
          <div id="certificate-file-status" style="color: #71717a; font-size: 0.8125rem;">No PDF uploaded yet.</div>
        </div>
        
        <div>
          <label for="thumbnail-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Icon/Logo URL (Optional)</label>
          <input 
            type="text" 
            id="thumbnail-url" 
            placeholder="Link to issuer logo"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="order-index" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Order Index</label>
          <input 
            type="number" 
            id="order-index" 
            value="0"
            style="width: 100px; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
          <button 
            type="button" 
            onclick="closeModal()"
            style="padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; cursor: pointer; background-color: #f9fafb;"
          >
            Cancel
          </button>
          <button 
            type="submit"
            style="padding: 0.5rem 1rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer;"
          >
            Save Certification
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Load certifications on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadCertifications();
  });
  
  // Load certifications from API
  async function loadCertifications() {
    try {
      const certifications = await api('GET', '/api/certifications');
      renderCertificationsTable(certifications);
    } catch (error) {
      console.error('Error loading certifications:', error);
    }
  }
  
  // Render certifications in the table
  function renderCertificationsTable(certifications) {
    const tbody = document.getElementById('certifications-table-body');
    tbody.innerHTML = '';
    
    certifications.forEach(cert => {
      const certificateAction = cert.certificate_url
        ? `<a href="${cert.certificate_url}" target="_blank" rel="noopener noreferrer" style="margin-left: 0.5rem; color: #18181b;">PDF</a>`
        : '';
      const row = document.createElement('tr');
      row.innerHTML = `
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${cert.title}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${cert.issuer}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${cert.issue_date || ''}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">
          <button onclick="openModal(${cert.id})" style="margin-right: 0.5rem; padding: 0.25rem 0.5rem; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Edit</button>
          ${certificateAction}
          <button onclick="deleteCertification(${cert.id})" style="padding: 0.25rem 0.5rem; background-color: #fee2e2; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Delete</button>
        </td>
      `;
      tbody.appendChild(row);
    });
  }
  
  // Open modal for adding/editing a certification
  function openModal(certId) {
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modal-title');
    const form = document.getElementById('certification-form');
    
    // Reset form
    form.reset();
    document.getElementById('certification-id').value = '';
    document.getElementById('certificate-url').value = '';
    updateCertificateFileStatus('');
    
    if (certId) {
      // Editing existing certification
      modalTitle.textContent = 'Edit Certification';
      
      // Find the certification and populate the form
      api('GET', '/api/certifications').then(certs => {
        const cert = certs.find(c => c.id === certId);
        if (cert) {
          document.getElementById('certification-id').value = cert.id;
          document.getElementById('title').value = cert.title;
          document.getElementById('issuer').value = cert.issuer;
          document.getElementById('issue-date').value = cert.issue_date || '';
          document.getElementById('expiry-date').value = cert.expiry_date || '';
          document.getElementById('credential-id').value = cert.credential_id || '';
          document.getElementById('credential-url').value = cert.credential_url || '';
          document.getElementById('certificate-url').value = cert.certificate_url || '';
          updateCertificateFileStatus(cert.certificate_url || '');
          document.getElementById('thumbnail-url').value = cert.thumbnail_url || '';
          document.getElementById('order-index').value = cert.order_index || 0;
        }
      });
    } else {
      // Adding new certification
      modalTitle.textContent = 'Add New Certification';
    }
    
    modal.style.display = 'flex';
  }
  
  // Close modal
  function closeModal() {
    document.getElementById('modal').style.display = 'none';
  }

  function updateCertificateFileStatus(url, fileName = '') {
    const status = document.getElementById('certificate-file-status');

    if (fileName) {
      status.textContent = `Selected: ${fileName}`;
      return;
    }

    if (url) {
      status.innerHTML = `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color: #18181b;">Current PDF</a>`;
      return;
    }

    status.textContent = 'No PDF uploaded yet.';
  }

  document.getElementById('certificate-file').addEventListener('change', (e) => {
    const file = e.target.files?.[0];

    if (!file) {
      updateCertificateFileStatus(document.getElementById('certificate-url').value);
      return;
    }

    const isPdf = file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
    if (!isPdf) {
      e.target.value = '';
      showToast('Only PDF files are allowed', 'error');
      updateCertificateFileStatus(document.getElementById('certificate-url').value);
      return;
    }

    updateCertificateFileStatus('', file.name);
  });
  
  // Handle form submission
  document.getElementById('certification-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    const certId = document.getElementById('certification-id').value;
    
    try {
      let certificateUrl = document.getElementById('certificate-url').value;
      const certificateFile = document.getElementById('certificate-file').files[0];

      if (certificateFile) {
        const isPdf = certificateFile.type === 'application/pdf' || certificateFile.name.toLowerCase().endsWith('.pdf');
        if (!isPdf) {
          throw new Error('Only PDF files are allowed');
        }

        showToast('Uploading certificate PDF...');
        try {
          certificateUrl = await uploadFile(certificateFile, 'certifications');
          document.getElementById('certificate-url').value = certificateUrl;
        } catch (uploadError) {
          throw new Error('Failed to upload certificate PDF: ' + uploadError.message);
        }
      }

      const formData = {
        id: certId ? parseInt(certId) : undefined,
        title: document.getElementById('title').value,
        issuer: document.getElementById('issuer').value,
        issueDate: document.getElementById('issue-date').value,
        expiryDate: document.getElementById('expiry-date').value,
        credentialId: document.getElementById('credential-id').value,
        credentialUrl: document.getElementById('credential-url').value,
        certificateUrl,
        thumbnailUrl: document.getElementById('thumbnail-url').value,
        orderIndex: parseInt(document.getElementById('order-index').value) || 0
      };
    
      let response;
      if (certId) {
        // Update existing certification
        response = await api('PUT', `/api/admin/certifications/${certId}`, formData);
      } else {
        // Create new certification
        response = await api('POST', '/api/admin/certifications', formData);
      }
      
      if (response.success || response.id) {
        showToast(certId ? 'Certification updated!' : 'Certification created!', 'success');
        closeModal();
        loadCertifications(); // Reload the table
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
        } catch (deployError) {
          console.error('Deploy failed:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to save certification', 'error');
      }
    } catch (error) {
      console.error('Error saving certification:', error);
      showToast(error.message || 'Failed to save certification', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
  
  // Delete a certification
  async function deleteCertification(certId) {
    if (!confirm('Are you sure you want to delete this certification?')) {
      return;
    }
    
    try {
      const response = await api('DELETE', `/api/admin/certifications/${certId}`);
      
      if (response.success) {
        showToast('Certification deleted!', 'success');
        loadCertifications(); // Reload the table
        
        // Trigger deploy after deletion
        try {
          await triggerDeploy();
          console.log('Deploy triggered after deleting certification');
        } catch (deployError) {
          console.error('Deploy failed after deleting certification:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to delete certification');
      }
    } catch (error) {
      console.error('Error deleting certification:', error);
      showToast('Failed to delete certification');
    }
  }
</script>
