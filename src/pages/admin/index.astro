---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin Dashboard - System Status">
  <div style="max-width: 800px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h1 style="font-size: 1.5rem; font-weight: 600; margin: 0; color: #111;">System Status</h1>
      <span style="font-size: 0.75rem; color: #9ca3af; font-family: monospace;">Source: official cloudflarestatus.com</span>
    </div>
    
    <!-- Overall Status Banner -->
    <div id="overall-status" style="background-color: #f3f4f6; color: #374151; padding: 1.5rem; border-radius: 0.5rem; margin-bottom: 2.5rem; display: flex; align-items: center; gap: 1rem; transition: all 0.3s ease;">
      <div id="overall-icon" style="width: 24px; height: 24px; border-radius: 50%; background-color: #9ca3af;"></div>
      <span id="overall-text" style="font-size: 1.25rem; font-weight: bold;">Connecting to Cloudflare...</span>
    </div>

    <!-- Components List -->
    <div style="border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; background-color: #fff;">
      <div style="padding: 1rem 1.5rem; border-bottom: 1px solid #e5e7eb; background-color: #f9fafb; font-size: 0.875rem; font-weight: 600; color: #6b7280; display: flex; justify-content: space-between;">
        <span>Infrastructure Components</span>
        <span>Official Status</span>
      </div>
      
      <div id="components-container">
        <!-- Components will be populated dynamically -->
        <div style="padding: 2rem; text-align: center; color: #9ca3af;">Loading official data...</div>
      </div>
    </div>

    <!-- System Maintenance Tool -->
    <div style="margin-top: 3rem; padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 0.5rem; background-color: #f9fafb;">
      <h2 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem;">Site Maintenance</h2>
      <p style="font-size: 0.875rem; color: #6b7280; margin-bottom: 1.5rem;">Trigger a manual static site rebuild to ensure production environment is perfectly synced with the database.</p>
      
      <button 
        id="deploy-btn"
        onclick="handleDeploy()"
        style="background-color: #000; color: #fff; padding: 0.625rem 1.25rem; border: none; border-radius: 0.375rem; cursor: pointer; font-size: 0.875rem; font-weight: 500;"
      >
        Rebuild Production Site
      </button>
      <p id="deploy-status" style="margin-top: 1rem; font-size: 0.875rem; display: none;"></p>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async () => {
    checkHealth();
  });

  async function checkHealth() {
    const overallBanner = document.getElementById('overall-status');
    const overallIcon = document.getElementById('overall-icon');
    const overallText = document.getElementById('overall-text');
    const componentsContainer = document.getElementById('components-container');
    
    try {
      const health = await api('GET', '/api/admin/health');
      
      // Update overall banner based on official data
      const isAllOk = health.indicator === 'none';
      
      if (isAllOk) {
        overallBanner.style.backgroundColor = '#10b981';
        overallBanner.style.color = '#fff';
        overallIcon.style.backgroundColor = '#fff';
        overallText.textContent = health.official || 'All Systems Operational';
      } else {
        overallBanner.style.backgroundColor = health.indicator === 'critical' ? '#ef4444' : '#f59e0b';
        overallBanner.style.color = '#fff';
        overallIcon.style.backgroundColor = '#fff';
        overallText.textContent = health.official || 'Service Disruption Detected';
      }

      // Render official components
      componentsContainer.innerHTML = '';
      Object.entries(health.components).forEach(([name, status], index, array) => {
        const isLast = index === array.length - 1;
        const row = document.createElement('div');
        row.style.padding = '1.25rem 1.5rem';
        if (!isLast) row.style.borderBottom = '1px solid #f3f4f6';
        row.style.display = 'flex';
        row.style.justifyContent = 'space-between';
        row.style.alignItems = 'center';
        
        row.innerHTML = `
          <div>
            <div style="font-weight: 500;">${name}</div>
            <div style="font-size: 0.75rem; color: #9ca3af; margin-top: 0.25rem;">Official Cloudflare Infrastructure</div>
          </div>
          <span style="color: ${status === 'operational' ? '#10b981' : '#ef4444'}; font-weight: 600; font-size: 0.875rem;">
            ${status.charAt(0).toUpperCase() + status.slice(1)}
          </span>
        `;
        componentsContainer.appendChild(row);
      });
      
    } catch (error) {
      console.error('Health check failed:', error);
      overallBanner.style.backgroundColor = '#f59e0b';
      overallBanner.style.color = '#fff';
      
      const errorMsg = error.message || 'Unknown error';
      overallText.textContent = 'Connection Issue';
      componentsContainer.innerHTML = `<div style="padding: 2rem; text-align: center;">
        <div style="color: #ef4444; font-weight: bold; margin-bottom: 0.5rem;">Unable to load official status</div>
        <div style="color: #6b7280; font-size: 0.75rem;">Error: ${errorMsg}</div>
        <div style="color: #6b7280; font-size: 0.75rem; margin-top: 1rem;">Make sure your API Worker is deployed and reachable.</div>
      </div>`;
    }
  }

  async function handleDeploy() {
    const deployBtn = document.getElementById('deploy-btn');
    const statusEl = document.getElementById('deploy-status');
    
    deployBtn.disabled = true;
    deployBtn.textContent = 'Maintenance in progress...';
    statusEl.style.display = 'block';
    statusEl.textContent = 'Requesting Cloudflare build...';
    statusEl.style.color = '#6b7280';
    
    try {
      await triggerDeploy();
      showToast('Build triggered successfully!', 'success');
      statusEl.textContent = 'Success: Production build is now running.';
      statusEl.style.color = '#10b981';
    } catch (error) {
      console.error('Deploy error:', error);
      showToast(`Build failed: ${error.message}`, 'error');
      statusEl.textContent = `Error: ${error.message}`;
      statusEl.style.color = '#ef4444';
    } finally {
      deployBtn.disabled = false;
      deployBtn.textContent = 'Rebuild Production Site';
    }
  }
</script>