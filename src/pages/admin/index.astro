---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin Dashboard - System Status">
  <!-- Page header -->
  <div style="margin-bottom: 2rem;">
    <h1 class="page-title" style="margin-bottom: 0.25rem;">Overview</h1>
    <p style="font-size: 0.875rem; color: var(--color-muted); margin: 0;">Everything running your site, at a glance.</p>
  </div>

  <!-- Overall Status Banner -->
  <div id="overall-status" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 0.5rem; border: 1px solid var(--color-border); background-color: var(--color-surface); margin-bottom: 1.5rem; transition: all 0.3s ease;">
    <div id="overall-indicator" style="width: 8px; height: 8px; border-radius: 9999px; background-color: #a1a1aa; flex-shrink: 0;"></div>
    <span id="overall-text" style="font-size: 0.875rem; font-weight: 500; color: var(--color-muted);">Connecting to Cloudflare...</span>
  </div>

  <!-- Components List -->
  <div style="border: 1px solid var(--color-border); border-radius: 0.5rem; overflow: hidden; background-color: var(--color-surface); margin-bottom: 1.5rem;">
    <div style="padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center;">
      <span style="font-size: 0.8125rem; font-weight: 600; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.04em;">Infrastructure</span>
      <span style="font-size: 0.8125rem; font-weight: 600; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.04em;">Status</span>
    </div>

    <div id="components-container">
      <div style="padding: 2rem; text-align: center; color: var(--color-muted); font-size: 0.875rem;">Loading official data...</div>
    </div>
  </div>

  <!-- Site Maintenance -->
  <div style="border: 1px solid var(--color-border); border-radius: 0.5rem; background-color: var(--color-surface); padding: 1.25rem;">
    <h2 style="font-size: 0.9375rem; font-weight: 600; margin: 0 0 0.375rem 0; color: var(--color-text);">Site Maintenance</h2>
    <p style="font-size: 0.8125rem; color: var(--color-muted); margin: 0 0 1.25rem 0; line-height: 1.5;">Trigger a manual static site rebuild to ensure production environment is perfectly synced with the database.</p>

    <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
      <button
        id="deploy-btn"
        onclick="handleDeploy()"
        style="background-color: var(--color-primary); color: #fff; padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; cursor: pointer; font-size: 0.8125rem; font-weight: 500; font-family: inherit; transition: opacity 0.15s;"
      >
        Rebuild Production Site
      </button>
      <span id="deploy-status" style="font-size: 0.8125rem; display: none;"></span>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async () => {
    checkHealth();
  });

  async function checkHealth() {
    const overallStatus = document.getElementById('overall-status');
    const overallIndicator = document.getElementById('overall-indicator');
    const overallText = document.getElementById('overall-text');
    const componentsContainer = document.getElementById('components-container');

    try {
      const health = await api('GET', '/api/admin/health');

      const isAllOk = health.indicator === 'none';

      if (isAllOk) {
        overallStatus.style.borderColor = '#bbf7d0';
        overallStatus.style.backgroundColor = '#f0fdf4';
        overallIndicator.style.backgroundColor = '#16a34a';
        overallText.style.color = '#16a34a';
        overallText.textContent = health.official || 'All Systems Operational';
      } else {
        const isCritical = health.indicator === 'critical';
        overallStatus.style.borderColor = isCritical ? '#fecaca' : '#fde68a';
        overallStatus.style.backgroundColor = isCritical ? '#fef2f2' : '#fffbeb';
        overallIndicator.style.backgroundColor = isCritical ? '#dc2626' : '#d97706';
        overallText.style.color = isCritical ? '#dc2626' : '#d97706';
        overallText.textContent = health.official || 'Service Disruption Detected';
      }

      // Render official components
      componentsContainer.innerHTML = '';
      const entries = Object.entries(health.components);
      entries.forEach(([name, status], index) => {
        const isLast = index === entries.length - 1;
        const isOp = status === 'operational';
        const row = document.createElement('div');
        row.style.padding = '0.875rem 1.25rem';
        if (!isLast) row.style.borderBottom = '1px solid var(--color-border)';
        row.style.display = 'flex';
        row.style.justifyContent = 'space-between';
        row.style.alignItems = 'center';

        row.innerHTML = `
          <div>
            <div style="font-size: 0.875rem; font-weight: 500; color: var(--color-text);">${name}</div>
            <div style="font-size: 0.75rem; color: var(--color-muted); margin-top: 0.125rem;">Official Cloudflare Infrastructure</div>
          </div>
          <span style="
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.25rem 0.625rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
            background-color: ${isOp ? '#f0fdf4' : '#fef2f2'};
            color: ${isOp ? '#16a34a' : '#dc2626'};
            border: 1px solid ${isOp ? '#bbf7d0' : '#fecaca'};
          ">
            <span style="width: 6px; height: 6px; border-radius: 50%; background-color: currentColor; display: inline-block;"></span>
            ${status.charAt(0).toUpperCase() + status.slice(1)}
          </span>
        `;
        componentsContainer.appendChild(row);
      });

    } catch (error) {
      console.error('Health check failed:', error);
      overallStatus.style.borderColor = '#fde68a';
      overallStatus.style.backgroundColor = '#fffbeb';
      overallIndicator.style.backgroundColor = '#d97706';
      overallText.style.color = '#d97706';
      overallText.textContent = 'Connection Issue';

      const errorMsg = error.message || 'Unknown error';
      componentsContainer.innerHTML = `
        <div style="padding: 2rem; text-align: center;">
          <div style="font-size: 0.875rem; font-weight: 500; color: #dc2626; margin-bottom: 0.375rem;">Unable to load official status</div>
          <div style="font-size: 0.75rem; color: var(--color-muted);">Error: ${errorMsg}</div>
          <div style="font-size: 0.75rem; color: var(--color-muted); margin-top: 0.5rem;">Make sure your API Worker is deployed and reachable.</div>
        </div>
      `;
    }
  }

  async function handleDeploy() {
    const deployBtn = document.getElementById('deploy-btn');
    const statusEl = document.getElementById('deploy-status');

    deployBtn.disabled = true;
    deployBtn.style.opacity = '0.5';
    deployBtn.textContent = 'Building...';
    statusEl.style.display = 'inline';
    statusEl.textContent = 'Requesting Cloudflare build...';
    statusEl.style.color = 'var(--color-muted)';

    try {
      await triggerDeploy();
      showToast('Build triggered successfully!', 'success');
      statusEl.textContent = 'Build started successfully.';
      statusEl.style.color = '#16a34a';
    } catch (error) {
      console.error('Deploy error:', error);
      showToast(`Build failed: ${error.message}`, 'error');
      statusEl.textContent = `Error: ${error.message}`;
      statusEl.style.color = '#dc2626';
    } finally {
      deployBtn.disabled = false;
      deployBtn.style.opacity = '1';
      deployBtn.textContent = 'Rebuild Production Site';
    }
  }
</script>
