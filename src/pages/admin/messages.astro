---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Messages">
  <h1>Manage Contact Messages</h1>
  
  <div class="table-container" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb;">
      <thead>
        <tr style="background-color: #f9fafb;">
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Name</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Email</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Subject</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Date</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Status</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody id="messages-table-body">
        <!-- Table rows will be populated by JavaScript -->
      </tbody>
    </table>
  </div>
  
  <!-- Modal for viewing message -->
  <div id="view-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background-color: #fff; width: 90%; max-width: 600px; border-radius: 0.5rem; padding: 1.5rem; position: relative;">
      <h2 id="view-modal-title">View Message</h2>
      
      <div id="message-content" style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">From:</label>
          <p id="message-from" style="margin: 0;"></p>
        </div>
        
        <div>
          <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Subject:</label>
          <p id="message-subject" style="margin: 0;"></p>
        </div>
        
        <div>
          <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Date:</label>
          <p id="message-date" style="margin: 0;"></p>
        </div>
        
        <div>
          <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Message:</label>
          <p id="message-text" style="margin: 0; white-space: pre-wrap;"></p>
        </div>
        
        <div>
          <label for="status-select" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Change Status:</label>
          <select 
            id="status-select" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          >
            <option value="unread">Unread</option>
            <option value="read">Read</option>
            <option value="archived">Archived</option>
          </select>
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
          <button 
            type="button" 
            onclick="closeViewModal()"
            style="padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; cursor: pointer; background-color: #f9fafb;"
          >
            Close
          </button>
          <button 
            type="button"
            onclick="updateStatus()"
            style="padding: 0.5rem 1rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer;"
          >
            Update Status
          </button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  let currentMessageId = null;
  
  // Load messages on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadMessages();
  });
  
  // Load messages from API
  async function loadMessages() {
    try {
      const messages = await api('GET', '/api/admin/messages');
      renderMessagesTable(messages);
    } catch (error) {
      console.error('Error loading messages:', error);
      showToast('Failed to load messages');
    }
  }
  
  // Render messages in the table
  function renderMessagesTable(messages) {
    const tbody = document.getElementById('messages-table-body');
    tbody.innerHTML = '';
    
    messages.forEach(msg => {
      const date = new Date(msg.submitted_at).toLocaleDateString();
      const row = document.createElement('tr');
      row.innerHTML = `
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${msg.name || 'N/A'}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${msg.email}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${msg.subject || 'No Subject'}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${date}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb; text-transform: capitalize;">${msg.status}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">
          <button onclick="openViewModal(${msg.id}, '${msg.name}', '${msg.email}', '${msg.subject}', '${msg.message}', '${msg.submitted_at}', '${msg.status}')" 
            style="margin-right: 0.5rem; padding: 0.25rem 0.5rem; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">
            View
          </button>
        </td>
      `;
      tbody.appendChild(row);
    });
  }
  
  // Open view modal for a message
  function openViewModal(id, name, email, subject, message, date, status) {
    currentMessageId = id;
    document.getElementById('message-from').textContent = `${name} (${email})`;
    document.getElementById('message-subject').textContent = subject || 'No Subject';
    document.getElementById('message-date').textContent = new Date(date).toLocaleString();
    document.getElementById('message-text').textContent = message;
    document.getElementById('status-select').value = status;
    
    document.getElementById('view-modal').style.display = 'flex';
  }
  
  // Close view modal
  function closeViewModal() {
    document.getElementById('view-modal').style.display = 'none';
  }
  
  // Update message status
  async function updateStatus() {
    if (!currentMessageId) return;
    
    const newStatus = document.getElementById('status-select').value;
    
    try {
      const response = await api('PUT', `/api/admin/messages/${currentMessageId}/status`, {
        status: newStatus
      });
      
      if (response.success) {
        closeViewModal();
        loadMessages(); // Reload the table
      } else {
        showToast(response.error || 'Failed to update status');
      }
    } catch (error) {
      console.error('Error updating status:', error);
      showToast('Failed to update status');
    }
  }
</script>