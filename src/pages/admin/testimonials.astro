---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Testimonials">
  <h1>Manage Testimonials</h1>
  
  <button 
    onclick="openModal(null)"
    style="background-color: #000; color: #fff; padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; cursor: pointer; margin-bottom: 1rem;"
  >
    + Add New Testimonial
  </button>
  
  <div class="table-container" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb;">
      <thead>
        <tr style="background-color: #f9fafb;">
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Client</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Role</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Featured</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody id="testimonials-table-body">
        <!-- Table rows will be populated by JavaScript -->
      </tbody>
    </table>
  </div>
  
  <!-- Modal -->
  <div id="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background-color: #fff; width: 90%; max-width: 600px; border-radius: 0.5rem; padding: 1.5rem; position: relative;">
      <h2 id="modal-title">Add New Testimonial</h2>
      
      <form id="testimonial-form" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" id="testimonial-id" />
        
        <div>
          <label for="client-name" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Client Name *</label>
          <input 
            type="text" 
            id="client-name" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="client-role" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Client Role</label>
          <input 
            type="text" 
            id="client-role" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="client-company" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Client Company</label>
          <input 
            type="text" 
            id="client-company" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="client-avatar-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Client Avatar URL</label>
          <input 
            type="text" 
            id="client-avatar-url" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="content" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Content *</label>
          <textarea 
            id="content" 
            required
            rows="4"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          ></textarea>
        </div>
        
        <div>
          <label for="rating" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Rating (1-5)</label>
          <input 
            type="number" 
            id="rating" 
            min="1" 
            max="5" 
            value="5"
            style="width: 100px; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; font-weight: 500;">
            <input type="checkbox" id="is-featured" />
            Featured
          </label>
        </div>
        
        <div>
          <label for="order-index" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Order Index</label>
          <input 
            type="number" 
            id="order-index" 
            value="0"
            style="width: 100px; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
          <button 
            type="button" 
            onclick="closeModal()"
            style="padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; cursor: pointer; background-color: #f9fafb;"
          >
            Cancel
          </button>
          <button 
            type="submit"
            style="padding: 0.5rem 1rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer;"
          >
            Save Testimonial
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Load testimonials on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadTestimonials();
  });
  
  // Load testimonials from API
  async function loadTestimonials() {
    try {
      const testimonials = await api('GET', '/api/testimonials');
      renderTestimonialsTable(testimonials);
    } catch (error) {
      console.error('Error loading testimonials:', error);
      showToast('Failed to load testimonials');
    }
  }
  
  // Render testimonials in the table
  function renderTestimonialsTable(testimonials) {
    const tbody = document.getElementById('testimonials-table-body');
    tbody.innerHTML = '';
    
    testimonials.forEach(t => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${t.client_name}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${t.client_role || ''}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${t.is_featured ? 'Yes' : 'No'}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">
          <button onclick="openModal(${t.id})" style="margin-right: 0.5rem; padding: 0.25rem 0.5rem; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Edit</button>
          <button onclick="deleteTestimonial(${t.id})" style="padding: 0.25rem 0.5rem; background-color: #fee2e2; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Delete</button>
        </td>
      `;
      tbody.appendChild(row);
    });
  }
  
  // Open modal for adding/editing a testimonial
  function openModal(testimonialId) {
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modal-title');
    const form = document.getElementById('testimonial-form');
    
    // Reset form
    form.reset();
    document.getElementById('testimonial-id').value = '';
    document.getElementById('rating').value = 5;
    
    if (testimonialId) {
      // Editing existing testimonial
      modalTitle.textContent = 'Edit Testimonial';
      
      // Find the testimonial and populate the form
      api('GET', '/api/testimonials').then(testimonials => {
        const t = testimonials.find(item => item.id === testimonialId);
        if (t) {
          document.getElementById('testimonial-id').value = t.id;
          document.getElementById('client-name').value = t.client_name;
          document.getElementById('client-role').value = t.client_role || '';
          document.getElementById('client-company').value = t.client_company || '';
          document.getElementById('client-avatar-url').value = t.client_avatar_url || '';
          document.getElementById('content').value = t.content;
          document.getElementById('rating').value = t.rating || 5;
          document.getElementById('is-featured').checked = t.is_featured || false;
          document.getElementById('order-index').value = t.order_index || 0;
        }
      });
    } else {
      // Adding new testimonial
      modalTitle.textContent = 'Add New Testimonial';
    }
    
    modal.style.display = 'flex';
  }
  
  // Close modal
  function closeModal() {
    document.getElementById('modal').style.display = 'none';
  }
  
  // Handle form submission
  document.getElementById('testimonial-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const testimonialId = document.getElementById('testimonial-id').value;
    const formData = {
      id: testimonialId ? parseInt(testimonialId) : undefined,
      clientName: document.getElementById('client-name').value,
      clientRole: document.getElementById('client-role').value,
      clientCompany: document.getElementById('client-company').value,
      clientAvatarUrl: document.getElementById('client-avatar-url').value,
      content: document.getElementById('content').value,
      rating: parseInt(document.getElementById('rating').value) || 5,
      isFeatured: document.getElementById('is-featured').checked,
      orderIndex: parseInt(document.getElementById('order-index').value) || 0
    };
    
    try {
      let response;
      if (testimonialId) {
        // Update existing testimonial
        response = await api('PUT', `/api/admin/testimonials/${testimonialId}`, formData);
      } else {
        // Create new testimonial
        response = await api('POST', '/api/admin/testimonials', formData);
      }
      
      if (response.success || response.id) {
        closeModal();
        loadTestimonials(); // Reload the table
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
          console.log('Deploy triggered after saving testimonial');
        } catch (deployError) {
          console.error('Deploy failed after saving testimonial:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to save testimonial');
      }
    } catch (error) {
      console.error('Error saving testimonial:', error);
      showToast('Failed to save testimonial');
    }
  });
  
  // Delete a testimonial
  async function deleteTestimonial(testimonialId) {
    if (!confirm('Are you sure you want to delete this testimonial?')) {
      return;
    }
    
    try {
      const response = await api('DELETE', `/api/admin/testimonials/${testimonialId}`);
      
      if (response.success) {
        loadTestimonials(); // Reload the table
        
        // Trigger deploy after deletion
        try {
          await triggerDeploy();
          console.log('Deploy triggered after deleting testimonial');
        } catch (deployError) {
          console.error('Deploy failed after deleting testimonial:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to delete testimonial');
      }
    } catch (error) {
      console.error('Error deleting testimonial:', error);
      showToast('Failed to delete testimonial');
    }
  }
</script>