---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Admin - Experience">
  <h1>Manage Work Experience</h1>
  
  <button 
    onclick="openModal(null)"
    style="background-color: #000; color: #fff; padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; cursor: pointer; margin-bottom: 1rem;"
  >
    + Add New Experience
  </button>
  
  <div class="table-container" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb;">
      <thead>
        <tr style="background-color: #f9fafb;">
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Company</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Role</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Dates</th>
          <th style="padding: 0.75rem; text-align: left; border: 1px solid #e5e7eb;">Actions</th>
        </tr>
      </thead>
      <tbody id="experience-table-body">
        <!-- Table rows will be populated by JavaScript -->
      </tbody>
    </table>
  </div>
  
  <!-- Modal -->
  <div id="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background-color: #fff; width: 90%; max-width: 600px; border-radius: 0.5rem; padding: 1.5rem; position: relative;">
      <h2 id="modal-title">Add New Experience</h2>
      
      <form id="experience-form" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" id="experience-id" />
        
        <div>
          <label for="company" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Company *</label>
          <input 
            type="text" 
            id="company" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="company-link" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Company Link</label>
          <input 
            type="text" 
            id="company-link" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="role" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Role *</label>
          <input 
            type="text" 
            id="role" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="description" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Description</label>
          <textarea 
            id="description" 
            rows="3"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          ></textarea>
        </div>
        
        <div>
          <label for="start-date" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Start Date *</label>
          <input 
            type="date" 
            id="start-date" 
            required
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="end-date" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">End Date</label>
          <input 
            type="date" 
            id="end-date" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; font-weight: 500;">
            <input type="checkbox" id="is-current" />
            Is Current Job
          </label>
        </div>
        
        <div>
          <label for="achievements" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Achievements (one per line)</label>
          <textarea 
            id="achievements" 
            rows="3"
            placeholder="Enter one achievement per line"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none; font-family: monospace;" 
          ></textarea>
        </div>
        
        <div>
          <label for="badges" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Badges (comma-separated)</label>
          <input 
            type="text" 
            id="badges" 
            placeholder="badge1, badge2, badge3"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="logo-url" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Logo URL</label>
          <input 
            type="text" 
            id="logo-url" 
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div>
          <label for="order-index" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Order Index</label>
          <input 
            type="number" 
            id="order-index" 
            value="0"
            style="width: 100px; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; outline: none;" 
          />
        </div>
        
        <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
          <button 
            type="button" 
            onclick="closeModal()"
            style="padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; cursor: pointer; background-color: #f9fafb;"
          >
            Cancel
          </button>
          <button 
            type="submit"
            style="padding: 0.5rem 1rem; background-color: #000; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer;"
          >
            Save Experience
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Load experience on page load
  document.addEventListener('DOMContentLoaded', async () => {
    loadExperience();
  });
  
  // Load experience from API
  async function loadExperience() {
    try {
      const experience = await api('GET', '/api/experience');
      renderExperienceTable(experience);
    } catch (error) {
      console.error('Error loading experience:', error);
      showToast('Failed to load experience');
    }
  }
  
  // Render experience in the table
  function renderExperienceTable(experience) {
    const tbody = document.getElementById('experience-table-body');
    tbody.innerHTML = '';
    
    experience.forEach(exp => {
      const startDate = exp.start_date ? new Date(exp.start_date).toLocaleDateString() : '';
      const endDate = exp.end_date ? new Date(exp.end_date).toLocaleDateString() : (exp.is_current ? 'Present' : '');
      const dates = `${startDate} - ${endDate}`;
      
      const row = document.createElement('tr');
      row.innerHTML = `
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${exp.company}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${exp.role}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">${dates}</td>
        <td style="padding: 0.75rem; border: 1px solid #e5e7eb;">
          <button onclick="openModal(${exp.id})" style="margin-right: 0.5rem; padding: 0.25rem 0.5rem; background-color: #f3f4f6; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Edit</button>
          <button onclick="deleteExperience(${exp.id})" style="padding: 0.25rem 0.5rem; background-color: #fee2e2; border: 1px solid #d1d5db; border-radius: 0.25rem; cursor: pointer;">Delete</button>
        </td>
      `;
      tbody.appendChild(row);
    });
  }
  
  // Open modal for adding/editing experience
  function openModal(expId) {
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modal-title');
    const form = document.getElementById('experience-form');
    
    // Reset form
    form.reset();
    document.getElementById('experience-id').value = '';
    
    if (expId) {
      // Editing existing experience
      modalTitle.textContent = 'Edit Experience';
      
      // Find the experience and populate the form
      api('GET', '/api/experience').then(exp => {
        const expItem = exp.find(e => e.id === expId);
        if (expItem) {
          document.getElementById('experience-id').value = expItem.id;
          document.getElementById('company').value = expItem.company;
          document.getElementById('company-link').value = expItem.company_link || '';
          document.getElementById('role').value = expItem.role;
          document.getElementById('description').value = expItem.description || '';
          document.getElementById('start-date').value = expItem.start_date || '';
          document.getElementById('end-date').value = expItem.end_date || '';
          document.getElementById('is-current').checked = expItem.is_current;
          document.getElementById('achievements').value = (expItem.achievements || []).join('\n');
          document.getElementById('badges').value = (expItem.badges || []).join(', ');
          document.getElementById('logo-url').value = expItem.logo_url || '';
          document.getElementById('order-index').value = expItem.order_index || 0;
        }
      });
    } else {
      // Adding new experience
      modalTitle.textContent = 'Add New Experience';
    }
    
    modal.style.display = 'flex';
  }
  
  // Close modal
  function closeModal() {
    document.getElementById('modal').style.display = 'none';
  }
  
  // Handle form submission
  document.getElementById('experience-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const expId = document.getElementById('experience-id').value;
    const formData = {
      id: expId ? parseInt(expId) : undefined,
      company: document.getElementById('company').value,
      companyLink: document.getElementById('company-link').value,
      role: document.getElementById('role').value,
      description: document.getElementById('description').value,
      startDate: document.getElementById('start-date').value,
      endDate: document.getElementById('end-date').value,
      isCurrent: document.getElementById('is-current').checked,
      achievements: document.getElementById('achievements').value.split('\n').map(a => a.trim()).filter(a => a),
      badges: document.getElementById('badges').value.split(',').map(badge => badge.trim()).filter(badge => badge),
      logoUrl: document.getElementById('logo-url').value,
      orderIndex: parseInt(document.getElementById('order-index').value) || 0
    };
    
    try {
      let response;
      if (expId) {
        // Update existing experience
        response = await api('PUT', `/api/admin/experience/${expId}`, formData);
      } else {
        // Create new experience
        response = await api('POST', '/api/admin/experience', formData);
      }
      
      if (response.success || response.id) {
        closeModal();
        loadExperience(); // Reload the table
        
        // Trigger deploy after saving
        try {
          await triggerDeploy();
          console.log('Deploy triggered after saving experience');
        } catch (deployError) {
          console.error('Deploy failed after saving experience:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to save experience');
      }
    } catch (error) {
      console.error('Error saving experience:', error);
      showToast('Failed to save experience');
    }
  });
  
  // Delete experience
  async function deleteExperience(expId) {
    if (!confirm('Are you sure you want to delete this experience?')) {
      return;
    }
    
    try {
      const response = await api('DELETE', `/api/admin/experience/${expId}`);
      
      if (response.success) {
        loadExperience(); // Reload the table
        
        // Trigger deploy after deletion
        try {
          await triggerDeploy();
          console.log('Deploy triggered after deleting experience');
        } catch (deployError) {
          console.error('Deploy failed after deleting experience:', deployError);
        }
      } else {
        showToast(response.error || 'Failed to delete experience');
      }
    } catch (error) {
      console.error('Error deleting experience:', error);
      showToast('Failed to delete experience');
    }
  }
</script>