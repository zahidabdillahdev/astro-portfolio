---
import {CV_DATA} from '../data/cv';
import Layout from '../layouts/Layout.astro';
import Header from "../components/Header.astro";
import Summary from "../components/Summary.astro";
import WorkExperience from "../components/WorkExperience.astro";
import Education from "../components/Education.astro";
import Skills from "../components/Skills.astro";
import PrintInstruction from "../components/PrintInstruction.astro";
import Projects from "../components/Projects.astro";
import Certifications from "../components/Certifications.astro";
import Contact from "../components/Contact.astro";

// Fetch data from API during build
const workerUrl = 'https://portfolio-api.muhammadzahidabdillah.workers.dev';

function getOptimizedAssetUrl(url: string | undefined, options: string): string | undefined {
    if (!url) return undefined;

    try {
        const parsed = new URL(url);
        if (parsed.hostname !== 'assets.zahidabdillah.dev') {
            return url;
        }

        return `${parsed.origin}/cdn-cgi/image/${options}${parsed.pathname}${parsed.search}`;
    } catch {
        return url;
    }
}

async function fetchData(endpoint: string): Promise<any> {
    try {
        const response = await fetch(`${workerUrl}${endpoint}`);
        if (!response.ok) return null;
        return await response.json();
    } catch (e) {
        console.error(`Failed to fetch ${endpoint}:`, e);
        return null;
    }
}

const profile: any = await fetchData('/api/profile');
const projectsData: any = await fetchData('/api/projects');
const certificationsData: any = await fetchData('/api/certifications');
const experienceData: any = await fetchData('/api/experience');
const skillsData: any = await fetchData('/api/skills');
const educationData: any = await fetchData('/api/education');

// Map API data to CV_DATA format
const mergedData = {
    ...CV_DATA,
    name: profile?.full_name || CV_DATA.name,
    about: profile?.title || CV_DATA.about, 
    summary: profile?.about || profile?.summary || CV_DATA.summary,
    avatarUrl: profile?.avatar_url || CV_DATA.avatarUrl,
    location: profile?.location || CV_DATA.location,
    locationLink: null,
    personalWebsiteUrl: profile?.website_url || CV_DATA.personalWebsiteUrl,
    contact: {
        ...CV_DATA.contact,
        email: profile?.email || CV_DATA.contact.email,
        tel: profile?.tel || CV_DATA.contact.tel,
        resumeUrl: profile?.resume_url || CV_DATA.contact.resumeUrl,
        social: [
            ...(profile?.linkedin_url ? [{ name: 'LinkedIn', url: profile.linkedin_url }] : []),
            ...(profile?.instagram_url ? [{ name: 'Instagram', url: profile.instagram_url }] : [])
        ]
    },
    work: (experienceData as any[]) || CV_DATA.work,
    education: (educationData as any[]) || CV_DATA.education,
    skills: (skillsData as any[])?.map((s: any) => s.name) || CV_DATA.skills,
    projects: (projectsData as any[]) || CV_DATA.projects,
    certifications: (certificationsData as any[]) || CV_DATA.certifications
};

const {name, projects, certifications} = mergedData;
const pageTitle = name ? `${name} | CV` : "Digital Marketing Portfolio";
const optimizedAvatarUrl = getOptimizedAssetUrl(mergedData.avatarUrl, 'width=224,quality=85,format=auto');
const optimizedFaviconUrl = getOptimizedAssetUrl(mergedData.avatarUrl, 'width=64,quality=85,format=auto');

const siteUrl = 'https://zahidabdillah.dev';
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": mergedData.name || undefined,
    "jobTitle": mergedData.about || undefined,
    "description": mergedData.summary || undefined,
    "url": siteUrl,
    "image": mergedData.avatarUrl || undefined,
    "email": mergedData.contact.email || undefined,
    "telephone": mergedData.contact.tel || undefined,
    "address": mergedData.location ? {
        "@type": "PostalAddress",
        "addressLocality": mergedData.location
    } : undefined,
    "sameAs": mergedData.contact.social?.map((s: any) => s.url).filter(Boolean) || []
};
---
<Layout
    title={pageTitle}
    description={mergedData.summary || "Digital Marketing Portfolio"}
    image={mergedData.avatarUrl}
    favicon={optimizedFaviconUrl}
    jsonLd={jsonLd}
>
    <main class="container relative mx-auto scroll-my-12 overflow-auto p-4 print:p-11 md:p-16" id="main-content">
        <section class="mx-auto w-full max-w-2xl space-y-8 bg-white print:space-y-4" aria-label="CV Content">
            <Header data={{ ...mergedData, avatarUrl: optimizedAvatarUrl || mergedData.avatarUrl }}/>
            <div class="space-y-8 print:space-y-4">
                <Summary data={mergedData}/>
                <WorkExperience data={mergedData}/>
                <Education data={mergedData}/>
                <Skills data={mergedData}/>
                <Projects projects={projects || []} />
                <Certifications certifications={certifications || []} />
                <Contact data={mergedData}/>
            </div>
        </section>
        <PrintInstruction/>
    </main>
</Layout>

<script is:inline define:vars={{ workerUrl }}>
  const liveSections = [
    { endpoint: '/api/experience', render: renderExperience, containerId: 'experience-list' },
    { endpoint: '/api/projects', render: renderProjects, containerId: 'projects-list' },
    { endpoint: '/api/certifications', render: renderCertifications, containerId: 'certifications-list' }
  ];

  function refreshSection(section) {
    const container = document.getElementById(section.containerId);
    if (!container || container.dataset.liveLoaded === 'true') return;

    container.dataset.liveLoaded = 'true';

    fetch(`${workerUrl}${section.endpoint}`)
      .then((response) => response.ok ? response.json() : Promise.reject(new Error(`Failed to fetch ${section.endpoint}`)))
      .then((items) => {
        if (!Array.isArray(items)) return;
        section.render(container, items);
      })
      .catch((error) => {
        container.dataset.liveLoaded = 'error';
        console.error(`Live refresh failed for ${section.endpoint}:`, error);
      });
  }

  function setupLiveSections() {
    if (!('IntersectionObserver' in window)) {
      window.setTimeout(() => {
        liveSections.forEach(refreshSection);
      }, 250);
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const section = liveSections.find(({ containerId }) => containerId === entry.target.id);
        if (!section) return;

        refreshSection(section);
        observer.unobserve(entry.target);
      });
    }, {
      rootMargin: '200px 0px',
      threshold: 0.01
    });

    liveSections.forEach((section) => {
      const container = document.getElementById(section.containerId);
      if (!container) return;
      observer.observe(container);
    });
  }

  window.addEventListener('load', () => {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(setupLiveSections, { timeout: 2000 });
      return;
    }

    window.setTimeout(setupLiveSections, 250);
  });

  function renderProjects(container, projects) {
    container.replaceChildren();

    if (!projects.length) {
      container.appendChild(createEmptyState('Significant projects and case studies will be listed here shortly.'));
      return;
    }

    projects.forEach((project) => {
      const card = createElement('div', 'group flex flex-col h-full border border-gray-200 rounded-lg p-4 hover:border-black transition-colors duration-300');
      const header = createElement('div', 'flex justify-between items-start gap-4');
      const headingWrap = document.createElement('div');
      headingWrap.appendChild(createTextElement('h3', 'text-lg font-bold mb-1', project.title || 'Untitled Project'));

      if (project.client) {
        headingWrap.appendChild(createTextElement('p', 'text-sm text-gray-600 mb-2', `Client: ${project.client}`));
      }

      header.appendChild(headingWrap);
      card.appendChild(header);
      card.appendChild(createTextElement('p', 'text-sm text-gray-700 mt-2 mb-4 flex-grow', project.description || ''));

      const footer = createElement('div', 'mt-auto pt-2');
      if (Array.isArray(project.tags) && project.tags.length) {
        const tags = createElement('div', 'flex flex-wrap gap-2 mb-4');
        project.tags.forEach((tag) => {
          tags.appendChild(createTextElement('span', 'inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-semibold transition-colors', tag));
        });
        footer.appendChild(tags);
      }

      if (project.results && Object.keys(project.results).length) {
        const resultsWrap = createElement('div', 'mb-4');
        resultsWrap.appendChild(createTextElement('h4', 'text-sm font-semibold mb-2', 'Results:'));
        const list = createElement('ul', 'space-y-1');
        Object.entries(project.results).forEach(([key, value]) => {
          const item = createElement('li', 'flex justify-between text-xs');
          item.appendChild(createTextElement('span', 'text-gray-600', `${key}:`));
          item.appendChild(createTextElement('span', 'font-medium', String(value)));
          list.appendChild(item);
        });
        resultsWrap.appendChild(list);
        footer.appendChild(resultsWrap);
      }

      if (project.link_url) {
        footer.appendChild(createLinkButton(project.link_url, project.link_type));
      }

      card.appendChild(footer);
      container.appendChild(card);
    });
  }

  function renderCertifications(container, certifications) {
    container.replaceChildren();

    if (!certifications.length) {
      container.appendChild(createEmptyState('Professional credentials and active certifications will be updated soon.'));
      return;
    }

    certifications.forEach((certification) => {
      const card = createElement('div', 'flex flex-col h-full border border-gray-200 rounded-lg p-4');
      const header = createElement('div', 'flex justify-between items-start gap-4');
      const headingWrap = document.createElement('div');
      headingWrap.appendChild(createTextElement('h3', 'text-lg font-bold mb-1', certification.title || 'Untitled Certification'));
      headingWrap.appendChild(createTextElement('p', 'text-sm text-gray-600 mb-2', certification.issuer || ''));
      header.appendChild(headingWrap);
      card.appendChild(header);

      const meta = createElement('div', 'mt-2 mb-4');
      const metaText = createElement('p', 'text-sm text-gray-700');
      metaText.append('Issued: ');
      metaText.appendChild(createTimeNode(certification.issue_date));
      if (certification.expiry_date) {
        metaText.append(' · Expires: ');
        metaText.appendChild(createTimeNode(certification.expiry_date));
      }
      meta.appendChild(metaText);
      card.appendChild(meta);

      const footer = createElement('div', 'mt-auto flex gap-2');
      if (certification.credential_url) {
        footer.appendChild(createRawLinkButton(certification.credential_url, 'View Credential', 'View', 'px-2 text-xs'));
      }
      card.appendChild(footer);
      container.appendChild(card);
    });
  }

  function renderExperience(container, experiences) {
    container.replaceChildren();

    if (!experiences.length) {
      container.appendChild(createEmptyState('Professional work history and career milestones are currently being updated.'));
      return;
    }

    experiences.forEach((item) => {
      const article = document.createElement('article');
      article.setAttribute('role', 'article');
      const shell = createElement('div', 'rounded-lg bg-card text-card-foreground py-1 print:py-0');
      const header = createElement('div', 'flex flex-col space-y-1.5 print:space-y-1');
      const topRow = createElement('div', 'flex items-center justify-between gap-x-2 text-base');
      const companyTitle = createElement('h3', 'inline-flex items-center justify-center gap-x-1 font-semibold leading-none print:text-sm');
      const companyLink = document.createElement('a');
      companyLink.className = 'hover:underline';
      companyLink.href = item.company_link || '#';
      companyLink.target = '_blank';
      companyLink.rel = 'noopener noreferrer';
      companyLink.setAttribute('aria-label', `${item.company || 'Company'} company link`);
      companyLink.textContent = item.company || 'Company';
      companyTitle.appendChild(companyLink);
      topRow.appendChild(companyTitle);
      topRow.appendChild(createTextElement('div', 'text-sm tabular-nums text-gray-500', `${item.start_date || ''} - ${item.end_date || 'Present'}`));
      header.appendChild(topRow);
      header.appendChild(createTextElement('h4', 'text-sm font-semibold leading-none flex flex-col space-y-1.5 print:text-[12px]', item.role || ''));
      shell.appendChild(header);

      const body = createElement('div', 'text-pretty text-sm text-muted-foreground');
      const bodyInner = createElement('div', 'mt-2 text-xm text-foreground/80 print:mt-1 print:text-[12px] text-pretty');
      if (item.description) {
        bodyInner.append(document.createTextNode(item.description));
      }

      if (Array.isArray(item.achievements) && item.achievements.length) {
        const list = createElement('ul', 'list-inside list-disc');
        item.achievements.forEach((achievement) => {
          list.appendChild(createTextElement('li', '', achievement));
        });
        bodyInner.appendChild(list);
      }

      body.appendChild(bodyInner);
      shell.appendChild(body);
      article.appendChild(shell);
      container.appendChild(article);
    });
  }

  function createLinkButton(href, linkType) {
    const label = getProjectLinkLabel(linkType);
    return createRawLinkButton(href, label, label, 'px-2');
  }

  function createRawLinkButton(href, ariaLabel, text, spanClassName) {
    const link = createElement('a', 'inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-input bg-background hover:bg-accent hover:text-accent-foreground size-8');
    link.href = href;
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
    link.setAttribute('aria-label', ariaLabel);
    link.appendChild(createTextElement('span', spanClassName, text));
    return link;
  }

  function getProjectLinkLabel(linkType) {
    if (linkType === 'pdf') return 'Download PDF';
    if (linkType === 'gdrive') return 'Open Drive';
    if (linkType === 'url') return 'View Project';
    return 'View Document';
  }

  function createTimeNode(value) {
    const time = document.createElement('time');
    time.textContent = formatMonthYear(value);
    return time;
  }

  function formatMonthYear(value) {
    if (!value) return '';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
  }

  function createEmptyState(text) {
    return createTextElement('p', 'text-sm text-muted-foreground italic', text);
  }

  function createTextElement(tagName, className, text) {
    const element = createElement(tagName, className);
    element.textContent = text;
    return element;
  }

  function createElement(tagName, className) {
    const element = document.createElement(tagName);
    if (className) element.className = className;
    return element;
  }
</script>
