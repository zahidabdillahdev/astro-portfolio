---
import { CV_DATA } from '../data/cv';
const { data = CV_DATA } = Astro.props;
const { contact } = data;

// Clean phone number for WhatsApp link
const waNumber = contact.tel ? contact.tel.replace(/[^0-9]/g, '') : '';
---

<section id="contact" class="flex min-h-0 flex-col gap-y-3 print:gap-y-1">
  <h2 class="text-xl font-bold">Connect</h2>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {contact.email && (
      <a href={`mailto:${contact.email}`} class="flex items-center gap-x-3 p-4 border border-gray-200 rounded-lg hover:border-black transition-all group">
        <div class="p-2 bg-gray-50 rounded-md group-hover:bg-gray-100">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">Email</p>
          <p class="text-sm font-semibold">{contact.email}</p>
        </div>
      </a>
    )}

    {contact.tel && (
      <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-3 p-4 border border-gray-200 rounded-lg hover:border-black transition-all group">
        <div class="p-2 bg-gray-50 rounded-md group-hover:bg-gray-100">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 14.5 15 14.5h.75c1.035 0 1.875-.84 1.875-1.875v-1.125c0-1.035-.84-1.875-1.875-1.875h-1.125c-1.035 0-1.875.84-1.875 1.875V19.5a13.233 13.233 0 0 1-5.456-2.816 13.233 13.233 0 0 1-2.816-5.456H4.875c1.035 0 1.875-.84 1.875-1.875V8.125c0-1.035-.84-1.875-1.875-1.875H3.75A1.875 1.875 0 0 0 2.25 8.125V6.75Z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">Phone / WhatsApp</p>
          <p class="text-sm font-semibold">{contact.tel}</p>
        </div>
      </a>
    )}

    {contact.social?.map((s: any) => (
      <a href={s.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-3 p-4 border border-gray-200 rounded-lg hover:border-black transition-all group">
        <div class="p-2 bg-gray-50 rounded-md group-hover:bg-gray-100">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">{s.name}</p>
          <p class="text-sm font-semibold">View Profile</p>
        </div>
      </a>
    ))}

    {contact.resumeUrl && (
      <a href={contact.resumeUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-3 p-4 border border-black bg-black text-white rounded-lg hover:bg-gray-800 transition-all group sm:col-span-2">
        <div class="p-2 bg-white/10 rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <div class="flex-1 flex justify-between items-center">
          <span class="text-sm font-bold uppercase tracking-wider">Download Professional Resume</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 animate-bounce">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
          </svg>
        </div>
      </a>
    )}
  </div>
</section>