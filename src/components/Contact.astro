---
import { CV_DATA } from '../data/cv';
import { Icon } from 'astro-icon/components';
const { data = CV_DATA } = Astro.props;
const { contact } = data;

// Clean phone number for WhatsApp link
const waNumber = contact.tel ? contact.tel.replace(/[^0-9]/g, '') : '';
---

<section id="contact" class="flex min-h-0 flex-col gap-y-3 print:gap-y-1">
  <h2 class="text-xl font-bold">Connect</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {contact.email && (
      <a href={`mailto:${contact.email}`} class="flex items-center gap-x-3 py-2 hover:opacity-70 transition-opacity group">
        <Icon name="mdi:gmail" class="size-6 shrink-0" style="color: #EA4335;" />
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">Email</p>
          <p class="text-sm font-semibold">{contact.email}</p>
        </div>
      </a>
    )}

    {contact.tel && (
      <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-3 py-2 hover:opacity-70 transition-opacity group">
        <Icon name="ic:baseline-whatsapp" class="size-6 shrink-0" style="color: #25D366;" />
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">WhatsApp</p>
          <p class="text-sm font-semibold">{contact.tel}</p>
        </div>
      </a>
    )}

    {contact.social?.map((s: any) => (
      <a href={s.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-3 py-2 hover:opacity-70 transition-opacity group">
        {s.name === 'LinkedIn'
          ? <Icon name="mdi:linkedin" class="size-6 shrink-0" style="color: #0A66C2;" />
          : <Icon name="mdi:web" class="size-6 shrink-0" />
        }
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase">{s.name}</p>
          <p class="text-sm font-semibold">View Profile</p>
        </div>
      </a>
    ))}

    {contact.resumeUrl && (
      <a href={contact.resumeUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-x-4 p-4 border border-black bg-black text-white rounded-lg hover:bg-gray-800 transition-colors group sm:col-span-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-7 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
        <div class="flex-1 flex justify-between items-center">
          <span class="text-sm font-bold uppercase tracking-wider">View Full Professional Resume</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>
    )}
  </div>
</section>
