---
import {CV_DATA} from "../data/cv";
import EducationItem from "./EducationItem.astro";

const {education} = CV_DATA;
---
<section class="flex min-h-0 flex-col gap-y-3 print:gap-y-1">
    <h2 class="text-xl font-bold" id="education-section">Education</h2>
    <div class="space-y-4" role="feed" aria-labelledby="education-section">
        {education && education.length > 0 ? (
            education.map((entry) => (
                <EducationItem {...entry}/>
            ))
        ) : (
            <p class="text-sm text-muted-foreground italic">Academic qualifications and certifications will be listed here.</p>
        )}
    </div>
</section>