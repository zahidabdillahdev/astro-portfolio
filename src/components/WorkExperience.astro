---
import {CV_DATA} from '../data/cv';
import WorkItem from "./WorkItem.astro";

const { data = CV_DATA } = Astro.props;
const {work} = data;
---
<section class="flex min-h-0 flex-col gap-y-3 print:gap-y-1">
    <h2 class="text-xl font-bold" id="work-experience">Work Experience</h2>
    {work && work.length > 0 ? (
        work.map((item: any) => (
            <WorkItem {...item}/>
        ))
    ) : (
        <p class="text-sm text-muted-foreground italic">Professional work history and career milestones are currently being updated.</p>
    )}
</section>