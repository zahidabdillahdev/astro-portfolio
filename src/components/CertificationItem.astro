---
import LinkButton from './common/LinkButton.astro';

export interface Props {
  certification: import('../data/cv').Certification;
}

const { certification } = Astro.props;
---

<div class="flex flex-col h-full border border-gray-200 rounded-lg p-6">
  <div class="flex justify-between items-start gap-4">
    <div>
      <h3 class="text-xl font-bold mb-1">{certification.title}</h3>
      <p class="text-gray-600 mb-2">{certification.issuer}</p>
    </div>
    {certification.thumbnailUrl && (
      <img 
        src={certification.thumbnailUrl} 
        alt={`${certification.title} thumbnail`}
        class="w-16 h-16 object-cover rounded-md border border-gray-200"
      />
    )}
  </div>
  
  <div class="mt-4 mb-6">
    <p class="text-gray-700 mb-2">
      Issued: <time>{new Date(certification.issueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </p>
    {certification.expiryDate && (
      <p class="text-gray-700">
        Expires: <time>{new Date(certification.expiryDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </p>
    )}
  </div>
  
  <div class="mt-auto flex gap-2">
    {certification.credentialUrl && (
      <LinkButton href={certification.credentialUrl} ariaLabel="View Credential">
        View Credential
      </LinkButton>
    )}
    
    {certification.certificateUrl && (
      <LinkButton href={certification.certificateUrl} ariaLabel="Download Certificate">
        Download Certificate
      </LinkButton>
    )}
  </div>
</div>