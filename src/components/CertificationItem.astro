---
export interface Props {
  certification: import('../data/cv').Certification;
}

const { certification } = Astro.props;
const issueDate = certification.issueDate || certification.issue_date;
const expiryDate = certification.expiryDate || certification.expiry_date;
const credentialId = certification.credentialId || certification.credential_id;
const credentialUrl = certification.credentialUrl || certification.credential_url;
const thumbnailUrl = certification.thumbnailUrl || certification.thumbnail_url;
---

<div class="flex flex-col h-full border border-gray-200 rounded-lg p-4">
  <div class="flex justify-between items-start gap-4">
    <div class="min-w-0 flex-1">
      <h3 class="text-lg font-bold mb-1">{certification.title}</h3>
      <p class="text-sm text-gray-600 mb-2">{certification.issuer}</p>
    </div>
    {thumbnailUrl && (
      <img
        src={thumbnailUrl}
        alt={`${certification.issuer || 'Certification issuer'} logo`}
        class="h-10 w-10 shrink-0 rounded-md border border-gray-200 bg-white object-contain p-1"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  
  <div class="mt-2 mb-4">
    <p class="text-sm text-gray-700">
      Issued: <time>{new Date(issueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
      {expiryDate && (
        <> · Expires: <time>{new Date(expiryDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time></>
      )}
    </p>
    {credentialId && <p class="mt-1 text-sm text-gray-600">Credential ID: {credentialId}</p>}
    {credentialUrl && (
      <p class="mt-1 text-sm">
        <a href={credentialUrl} target="_blank" rel="noopener noreferrer" class="text-gray-700 underline underline-offset-2 hover:text-black">
          Link Verify
        </a>
      </p>
    )}
  </div>
</div>
