---
import LinkButton from './common/LinkButton.astro';

export interface Props {
  certification: import('../data/cv').Certification;
}

const { certification } = Astro.props;
---

<div class="flex flex-col h-full border border-gray-200 rounded-lg p-4">
  <div class="flex justify-between items-start gap-4">
    <div>
      <h3 class="text-lg font-bold mb-1">{certification.title}</h3>
      <p class="text-sm text-gray-600 mb-2">{certification.issuer}</p>
    </div>
  </div>
  
  <div class="mt-2 mb-4">
    <p class="text-sm text-gray-700">
      Issued: <time>{new Date(certification.issueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
      {certification.expiryDate && (
        <> · Expires: <time>{new Date(certification.expiryDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time></>
      )}
    </p>
  </div>
  
  <div class="mt-auto flex gap-2">
    {certification.credentialUrl && (
      <LinkButton href={certification.credentialUrl} ariaLabel="View Credential">
        <span class="px-2 text-xs">View</span>
      </LinkButton>
    )}
    
    {certification.certificateUrl && (
      <LinkButton href={certification.certificateUrl} ariaLabel="Download Certificate">
        <span class="px-2 text-xs">Download</span>
      </LinkButton>
    )}
  </div>
</div>