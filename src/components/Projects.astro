---
import ProjectItem from './ProjectItem.astro';

interface Props {
  projects: import('../data/cv').Project[];
}

const { projects }: Props = Astro.props;
---

<section id="projects" class="py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-2">Projects</h2>
    <p class="text-gray-600 mb-12">Selected projects showcasing my work and expertise</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects?.map((project) => (
        <ProjectItem project={project} />
      ))}
    </div>
  </div>
</section>