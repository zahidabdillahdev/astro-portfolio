---
import {CV_DATA} from '../data/cv';
import LinkButton from "./common/LinkButton.astro";
import LinkedIn from "./icons/LinkedIn.astro";
import GitHub from "./icons/GitHub.astro";
import Email from "./icons/Email.astro";
import Phone from "./icons/Phone.astro";
import Globe from "./icons/Globe.astro";

const { data = CV_DATA } = Astro.props;
const {name, about, personalWebsiteUrl, contact, location, locationLink, avatarUrl} = data;

// Auto-detect country code from "City, XX" format for flag image
const countryMatch = location?.match(/,\s*([A-Z]{2})$/);
const countryCode = countryMatch ? countryMatch[1].toLowerCase() : null;
---
<header class="flex items-center justify-between">
    <div class="flex-1 space-y-1.5">
        <h1 class="text-2xl font-bold" id="cv-name">
            {name || "Your Name"}
        </h1>
        <p class="max-w-md text-pretty text-sm text-foreground/80 print:text-[12px]">
            {about || "Digital Marketing Professional | Specialist"}
        </p>
        <p class="max-w-md items-center text-pretty text-xs text-foreground">
            {location ? (
                locationLink ? (
                    <a class="inline-flex gap-x-1.5 align-baseline leading-none hover:underline"
                       href={locationLink}
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label={`Location: ${location}`}>
                        {countryCode
    ? <img src={`https://flagcdn.com/w20/${countryCode}.png`} srcset={`https://flagcdn.com/w40/${countryCode}.png 2x`} width="16" height="12" alt="" aria-hidden="true" loading="eager" style="display:inline-block;vertical-align:middle;border-radius:2px;"/>
    : <Globe class="size-3"/>
}
                        {location}
                    </a>
                ) : (
                    <span class="inline-flex gap-x-1.5 align-baseline leading-none" aria-label={`Location: ${location}`}>
                        {countryCode
    ? <img src={`https://flagcdn.com/w20/${countryCode}.png`} srcset={`https://flagcdn.com/w40/${countryCode}.png 2x`} width="16" height="12" alt="" aria-hidden="true" loading="eager" style="display:inline-block;vertical-align:middle;border-radius:2px;"/>
    : <Globe class="size-3"/>
}
                        {location}
                    </span>
                )
            ) : (
                <span class="inline-flex gap-x-1.5 align-baseline leading-none text-muted-foreground italic">
                    <Globe class="size-3"/>
                    Location information pending
                </span>
            )}
        </p>
        <div class="flex list-none gap-x-1 pt-1 text-sm text-foreground/80 print:hidden"
             aria-label="Contact links">
            {personalWebsiteUrl && (
                <LinkButton href={personalWebsiteUrl} ariaLabel="Website">
                    <Globe class="size-4"/>
                </LinkButton>
            )}
            {contact.email && (
                <LinkButton href={`mailto:${contact.email}`} ariaLabel="Email">
                    <Email class="size-4"/>
                </LinkButton>
            )}
            {contact.tel && (
                <LinkButton href={`tel:${contact.tel}`} ariaLabel="Phone">
                    <Phone class="size-4"/>
                </LinkButton>
            )}
            {contact.social?.map((social: any) => (
                <LinkButton href={social.url} ariaLabel={social.name}>
                    {social.name === 'GitHub' ? <GitHub class="size-4"/> : 
                     social.name === 'LinkedIn' ? <LinkedIn class="size-4"/> : 
                     <Globe class="size-4"/>}
                </LinkButton>
            ))}
        </div>
        <div class="hidden gap-x-2 text-sm text-foreground/80 print:flex print:flex-wrap gap-y-1 print:text-[12px]">
            {personalWebsiteUrl && (
                <>
                    <a class="underline hover:text-foreground/70" href={personalWebsiteUrl}>
                        {personalWebsiteUrl}
                    </a>
                    <span aria-hidden="true">|</span>
                </>
            )}
            {contact.email && (
                <>
                    <a class="underline hover:text-foreground/70" href={`mailto:${contact.email}`}>
                        {contact.email}
                    </a>
                    <span aria-hidden="true">|</span>
                </>
            )}
            {contact.tel && (
                <a class="underline hover:text-foreground/70" href={`tel:${contact.tel}`}>
                    {contact.tel}
                </a>
            )}
            {contact.social?.map((social: any, index: number) => (
                <>
                    {index === 0 && <span aria-hidden="true">|</span>}
                    <a class="underline hover:text-foreground/70" href={social.url}>
                        {social.url}
                    </a>
                    {index < contact.social.length - 1 && <span aria-hidden="true">|</span>}
                </>
            ))}
        </div>
    </div>
    <span class="relative flex shrink-0 overflow-hidden rounded-xl size-28 bg-gray-100 items-center justify-center border border-gray-200"
          aria-hidden="true">
        {avatarUrl ? (
            <img class="aspect-square h-full w-full object-cover" alt={`${name || 'User'}'s profile picture`} src={avatarUrl} width="112" height="112" fetchpriority="high" decoding="async"/>
        ) : (
            <div class="text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
            </div>
        )}
    </span>
</header>
