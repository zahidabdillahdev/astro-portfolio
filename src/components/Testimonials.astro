---
interface Props {
  testimonials: import('../data/cv').Testimonial[];
}

const { testimonials }: Props = Astro.props;

const getStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => i < rating);
};
---

<section id="testimonials" class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-2">Testimonials</h2>
    <p class="text-gray-600 mb-12">What people say about working with me</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials?.map((testimonial) => (
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            {testimonial.clientAvatarUrl ? (
              <img 
                src={testimonial.clientAvatarUrl} 
                alt={`${testimonial.clientName} avatar`}
                class="w-12 h-12 rounded-full object-cover mr-4 border border-gray-200"
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center mr-4">
                <span class="text-gray-600 font-medium">{testimonial.clientName.charAt(0)}</span>
              </div>
            )}
            <div>
              <h3 class="font-bold">{testimonial.clientName}</h3>
              {(testimonial.clientRole || testimonial.clientCompany) && (
                <p class="text-gray-600 text-sm">
                  {testimonial.clientRole}{testimonial.clientRole && testimonial.clientCompany ? ', ' : ''}{testimonial.clientCompany}
                </p>
              )}
            </div>
          </div>
          
          <p class="text-gray-700 italic mb-4">"{testimonial.content}"</p>
          
          {testimonial.rating !== undefined && (
            <div class="flex">
              {getStars(testimonial.rating).map((filled) => (
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  viewBox="0 0 24 24" 
                  fill={filled ? "#000" : "none"} 
                  stroke="#000" 
                  stroke-width="1" 
                  class="w-5 h-5"
                >
                  <path d="M11.47 3.84a.75.75 0 0 1 1.06 0l4.97 4.97c.212.212.499.367.81.446l3.75 1.25a.75.75 0 0 1 .0 1.5l-3.75 1.25a1.996 1.996 0 0 0-.81.446l-4.97 4.97a.75.75 0 0 1-1.06-1.06l4.69-4.69a.75.75 0 0 0-.22-.53l-3.6-3.6a.75.75 0 0 1 0-1.06l3.6-3.6a.75.75 0 0 0 .22-.53l-4.69-4.69Z" />
                  <path d="M3.75 2.25a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75c.414 0 .75-.336.75-.75V3a.75.75 0 0 0-.75-.75H3.75Z" />
                  <path d="M3 7.5a.75.75 0 0 1 .75-.75h.75a.75.75 0 0 1 0 1.5h-.75A.75.75 0 0 1 3 7.5Z" />
                  <path d="M3.75 12a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75c.414 0 .75-.336.75-.75v-.75a.75.75 0 0 0-.75-.75H3.75Z" />
                  <path d="M3 16.5a.75.75 0 0 1 .75-.75h.75a.75.75 0 0 1 0 1.5h-.75a.75.75 0 0 1-.75-.75Z" />
                  <path d="M12 2.25a.75.75 0 0 1 .75-.75h.75c.414 0 .75.336.75.75v.75c0 .414-.336.75-.75.75h-.75a.75.75 0 0 1-.75-.75V3Z" />
                  <path d="M16.5 3a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75V3a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M12 7.5a.75.75 0 0 1 .75-.75h.75a.75.75 0 0 1 0 1.5h-.75a.75.75 0 0 1-.75-.75Z" />
                  <path d="M16.5 8.25a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M12 12a.75.75 0 0 1 .75-.75h.75c.414 0 .75.336.75.75v.75c0 .414-.336.75-.75.75h-.75a.75.75 0 0 1-.75-.75v-.75Z" />
                  <path d="M16.5 12.75a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M12 16.5a.75.75 0 0 1 .75-.75h.75a.75.75 0 0 1 0 1.5h-.75a.75.75 0 0 1-.75-.75Z" />
                  <path d="M16.5 17.25a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M20.25 3a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75V3a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M20.25 7.5a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M20.25 12a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                  <path d="M20.25 16.5a.75.75 0 0 0-.75.75v.75c0 .414.336.75.75.75h.75a.75.75 0 0 0 .75-.75v-.75a.75.75 0 0 0-.75-.75h-.75Z" />
                </svg>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>