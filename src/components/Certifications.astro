---
import CertificationItem from './CertificationItem.astro';

interface Props {
  certifications: import('../data/cv').Certification[];
}

const { certifications }: Props = Astro.props;
---

<section id="certifications" class="py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-2">Certifications</h2>
    <p class="text-gray-600 mb-12">Professional credentials and certifications</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {certifications?.map((certification) => (
        <CertificationItem certification={certification} />
      ))}
    </div>
  </div>
</section>