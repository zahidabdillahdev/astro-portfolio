---
import CertificationItem from './CertificationItem.astro';

interface Props {
  certifications: import('../data/cv').Certification[];
}

const { certifications }: Props = Astro.props;
---

<section id="certifications" class="flex min-h-0 flex-col gap-y-3 print:gap-y-1">
  <h2 class="text-xl font-bold">Certifications</h2>
  <div class="flex flex-col gap-y-4">
    {certifications && certifications.length > 0 ? (
      certifications.map((certification) => (
        <CertificationItem certification={certification} />
      ))
    ) : (
      <p class="text-sm text-muted-foreground italic">Professional credentials and active certifications will be updated soon.</p>
    )}
  </div>
</section>