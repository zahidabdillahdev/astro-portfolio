---
export interface Props {
  title?: string;
}

const { title = 'Admin Dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      background-color: #fff;
      color: #000;
      display: flex;
    }
    
    .sidebar {
      width: 216px;
      min-height: 100vh;
      border-right: 1px solid #e5e7eb;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
    }
    
    .sidebar-nav {
      flex: 1;
    }
    
    .sidebar-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .sidebar-nav li {
      margin-bottom: 0.5rem;
    }
    
    .sidebar-nav a {
      display: block;
      padding: 0.75rem;
      text-decoration: none;
      color: #6b7280;
      border-radius: 0.375rem;
      transition: all 0.2s;
    }
    
    .sidebar-nav a:hover {
      background-color: #f3f4f6;
      color: #000;
    }
    
    .sidebar-nav a.active {
      background-color: #000;
      color: #fff;
    }
    
    .logout-link {
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid #e5e7eb;
    }
    
    .main-content {
      flex: 1;
      padding: 1.5rem;
    }
    
    .back-to-site {
      display: inline-block;
      margin-bottom: 1.5rem;
      padding: 0.5rem 1rem;
      background-color: #f3f4f6;
      color: #000;
      text-decoration: none;
      border-radius: 0.375rem;
      font-size: 0.875rem;
    }
    
    .back-to-site:hover {
      background-color: #e5e7eb;
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <nav class="sidebar-nav">
      <ul>
        <li><a href="/admin/" class={Astro.url.pathname === '/admin/' ? 'active' : ''}>Dashboard</a></li>
        <li><a href="/admin/profile" class={Astro.url.pathname === '/admin/profile' ? 'active' : ''}>Profile</a></li>
        <li><a href="/admin/projects" class={Astro.url.pathname === '/admin/projects' ? 'active' : ''}>Projects</a></li>
        <li><a href="/admin/certifications" class={Astro.url.pathname === '/admin/certifications' ? 'active' : ''}>Certifications</a></li>
        <li><a href="/admin/experience" class={Astro.url.pathname === '/admin/experience' ? 'active' : ''}>Experience</a></li>
        <li><a href="/admin/skills" class={Astro.url.pathname === '/admin/skills' ? 'active' : ''}>Skills</a></li>
        <li><a href="/admin/testimonials" class={Astro.url.pathname === '/admin/testimonials' ? 'active' : ''}>Testimonials</a></li>
        <li><a href="/admin/messages" class={Astro.url.pathname === '/admin/messages' ? 'active' : ''}>Messages</a></li>
      </ul>
    </nav>
    <div class="logout-link">
      <a href="https://zahidabdillah.cloudflareaccess.com/cdn-cgi/access/logout" class="logout-btn">Logout</a>
    </div>
  </aside>
  
  <main class="main-content">
    <a href="/" class="back-to-site">← View Site</a>
    <slot />
  </main>
  
  <script is:inline>
    // Global helper functions for API calls
    window.api = async function(method, url, body) {
      const options = {
        method,
        headers: {
          'Content-Type': 'application/json',
        },
      };
      
      if (body) {
        options.body = JSON.stringify(body);
      }
      
      const response = await fetch(url, options);
      return response.json();
    };
    
    // Upload file function
    window.uploadFile = async function(file, path) {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('path', path);
      
      const response = await fetch('/api/admin/upload', {
        method: 'POST',
        body: formData,
      });
      
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || 'Upload failed');
      }
      return result.url;
    };
    
    // Trigger deploy function
    window.triggerDeploy = async function() {
      const response = await fetch('/api/admin/deploy', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
      });
      
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || 'Deploy failed');
      }
      return result;
    };
  </script>
</body>
</html>