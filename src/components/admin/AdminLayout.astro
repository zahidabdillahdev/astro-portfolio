---
export interface Props {
  title?: string;
}

const { title = 'Admin Dashboard' } = Astro.props;

// Fetch avatar for favicon
const profileRes = await fetch('https://portfolio-api.muhammadzahidabdillah.workers.dev/api/profile').catch(() => null);
const profile = profileRes?.ok ? await profileRes.json() as any : null;
const faviconUrl = profile?.avatar_url || '/favicon.svg';
const faviconType = profile?.avatar_url ? 'image/webp' : 'image/svg+xml';
const firstName = profile?.full_name?.split(' ')[1] || profile?.full_name?.split(' ')[0] || 'Zahid';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <link rel="icon" type={faviconType} href={faviconUrl} />
  <style>
    :root {
      --font-family-base: "Source Serif 4", Georgia, "Times New Roman", serif;
      --color-bg: #fafafa;
      --color-surface: #ffffff;
      --color-border: #e4e4e7;
      --color-text: #18181b;
      --color-muted: #71717a;
      --color-active-bg: #f4f4f5;
      --color-primary: #18181b;
    }

    *, *::before, *::after {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      font-size: 16px;
      font-family: var(--font-family-base);
      font-optical-sizing: auto;
      font-style: normal;
      background-color: var(--color-bg);
      color: var(--color-text);
      display: flex;
      flex-direction: row;
      min-height: 100vh;
    }

    button,
    input,
    textarea,
    select {
      font: inherit;
    }

    /* Mobile Header */
    .mobile-header {
      display: none;
      width: 100%;
      padding: 0.875rem 1.25rem;
      border-bottom: 1px solid var(--color-border);
      background-color: var(--color-surface);
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1001;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-clock {
      font-size: 0.8125rem;
      color: var(--color-muted);
      letter-spacing: 0.02em;
    }

    .menu-toggle {
      background: none;
      border: 1px solid var(--color-border);
      border-radius: 0.375rem;
      font-size: 1rem;
      cursor: pointer;
      padding: 0.375rem 0.625rem;
      color: var(--color-text);
      line-height: 1;
    }

    /* Sidebar */
    .sidebar {
      width: 216px;
      min-height: 100vh;
      border-right: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      background-color: var(--color-surface);
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      transition: transform 0.25s ease;
      will-change: transform;
      flex-shrink: 0;
    }

    .sidebar-header {
      padding: 1.5rem 1rem 1rem;
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar-clock {
      font-size: 0.8125rem;
      color: var(--color-muted);
      margin-bottom: 0.875rem;
      letter-spacing: 0.02em;
      line-height: 1.6;
    }

    .sidebar-clock-time {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
      letter-spacing: 0.04em;
    }

    .sidebar-greeting {
      font-size: 1.0625rem;
      font-weight: 600;
      color: var(--color-text);
      line-height: 1.3;
    }

    /* Nav */
    .sidebar-nav {
      flex: 1;
      padding: 0.875rem 0.5rem;
    }

    .sidebar-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sidebar-nav li {
      margin-bottom: 0.125rem;
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5625rem 0.625rem;
      text-decoration: none;
      color: var(--color-muted);
      border-radius: 0.375rem;
      font-size: 0.875rem;
      font-weight: 450;
      transition: background-color 0.15s, color 0.15s;
      border-left: 3px solid transparent;
    }

    .sidebar-nav a:hover {
      background-color: var(--color-active-bg);
      color: var(--color-text);
    }

    .sidebar-nav a.active {
      background-color: var(--color-active-bg);
      color: var(--color-text);
      font-weight: 500;
      border-left-color: var(--color-primary);
      border-radius: 0 0.375rem 0.375rem 0;
    }

    .nav-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: currentColor;
      opacity: 0.4;
      flex-shrink: 0;
    }

    .sidebar-nav a.active .nav-dot {
      opacity: 1;
      background-color: var(--color-text);
    }

    /* Sidebar footer */
    .sidebar-footer {
      padding: 0.75rem 0.5rem;
      border-top: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }

    .sidebar-footer a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.625rem;
      text-decoration: none;
      font-size: 0.8125rem;
      border-radius: 0.375rem;
      transition: background-color 0.15s;
    }

    .view-site-link {
      color: var(--color-muted);
    }

    .view-site-link:hover {
      background-color: var(--color-active-bg);
      color: var(--color-text);
    }

    .logout-link {
      color: #ef4444;
    }

    .logout-link:hover {
      background-color: #fef2f2;
    }

    /* Main Content */
    .main-content {
      flex: 1;
      padding: 2rem 2.5rem;
      min-width: 0;
    }

    /* Toast */
    #toast-container {
      position: fixed;
      top: 1.5rem;
      right: 1.5rem;
      z-index: 2000;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .toast {
      padding: 0.75rem 1.25rem;
      background-color: var(--color-primary);
      color: #fff;
      border-radius: 0.5rem;
      box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.15), 0 2px 6px -1px rgba(0, 0, 0, 0.08);
      min-width: 240px;
      max-width: 360px;
      animation: toast-in 0.25s ease-out;
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1.4;
    }

    .toast.success {
      background-color: #16a34a;
    }

    .toast.error {
      background-color: #dc2626;
    }

    @keyframes toast-in {
      from { transform: translateX(calc(100% + 1.5rem)); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    @media (max-width: 768px) {
      #toast-container {
        top: 1rem;
        bottom: auto;
        right: 50%;
        transform: translateX(50%);
        width: calc(100% - 2rem);
        align-items: center;
      }

      .toast {
        width: 100%;
        max-width: 100%;
        text-align: center;
        animation: toast-in-mobile 0.25s ease-out;
      }
    }

    @keyframes toast-in-mobile {
      from { transform: translateY(-0.5rem); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    /* Global Form Styles */
    input[type="text"],
    input[type="email"],
    input[type="url"],
    input[type="number"],
    input[type="date"],
    input[type="file"],
    textarea,
    select {
      width: 100%;
      padding: 0.5rem 0.75rem;
      border: 1px solid #d4d4d8;
      border-radius: 0.375rem;
      font-size: 0.875rem;
      font-family: inherit;
      color: var(--color-text);
      background-color: var(--color-surface);
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    input[type="text"]:focus,
    input[type="email"]:focus,
    input[type="url"]:focus,
    input[type="number"]:focus,
    input[type="date"]:focus,
    textarea:focus,
    select:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(24, 24, 27, 0.08);
    }

    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text);
      margin-bottom: 0.375rem;
    }

    button[type="submit"] {
      background-color: var(--color-primary);
      color: #fff;
      padding: 0.5625rem 1.25rem;
      border: none;
      border-radius: 0.375rem;
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: inherit;
      transition: opacity 0.15s;
    }

    button[type="submit"]:hover {
      opacity: 0.85;
    }

    button[type="submit"]:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Page heading global */
    .page-title {
      font-size: 1.375rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 0 0 1.5rem 0;
    }

    @media (min-width: 1024px) {
      html {
        font-size: 17px;
      }
    }

    /* Responsive */
    @media (max-width: 768px) {
      body {
        flex-direction: column;
      }

      .mobile-header {
        display: flex;
      }

      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        z-index: 1002;
        transform: translateX(-100%);
        box-shadow: 4px 0 24px rgba(0, 0, 0, 0.08);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .main-content {
        padding: 1rem;
        margin-top: 56px;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
      }

      /* Prevent form overflow on mobile */
      form {
        max-width: 100% !important;
        width: 100%;
      }

      input,
      textarea,
      select {
        font-size: 16px !important;
        max-width: 100%;
      }

      input[type="number"] {
        width: 100% !important;
      }

      /* Modal inner padding reduced on small screens */
      [id="modal"] > div {
        padding: 1.25rem !important;
        margin-top: 1rem !important;
        margin-bottom: 1rem !important;
      }

      [id="modal"] form > div[style*="justify-content: flex-end"] {
        flex-direction: column-reverse;
        align-items: stretch !important;
      }

      [id="modal"] form > div[style*="justify-content: flex-end"] > button {
        width: 100%;
      }

      /* Table cells smaller on mobile */
      th, td {
        padding: 0.5rem !important;
        font-size: 0.8125rem;
      }

      #current-resume-link {
        flex-wrap: wrap;
      }

      #current-resume-link > * {
        max-width: 100%;
        word-break: break-word;
      }

      #profile-form > div[style*="flex-wrap: wrap"] {
        flex-direction: column;
      }

      #profile-form > div[style*="flex-wrap: wrap"] > div {
        width: 100%;
      }

      .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.35);
        z-index: 1001;
        backdrop-filter: blur(2px);
      }

      .sidebar-overlay.open {
        display: block;
      }
    }
  </style>
</head>
<body>
  <div id="toast-container"></div>
  <div class="sidebar-overlay" id="overlay" onclick="toggleSidebar()"></div>

  <header class="mobile-header">
    <div class="mobile-clock" id="mobile-clock">--:--</div>
    <button class="menu-toggle" onclick="toggleSidebar()">☰</button>
  </header>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-clock">
        <div class="sidebar-clock-time" id="sidebar-clock-time">--:--:--</div>
        <div id="sidebar-clock-date">---, -- --- ----</div>
      </div>
      <div class="sidebar-greeting" id="sidebar-greeting" data-name={firstName}></div>
    </div>

    <nav class="sidebar-nav">
      <ul>
        <li>
          <a href="/admin/" class={Astro.url.pathname === '/admin/' ? 'active' : ''}>
            <span class="nav-dot"></span>Dashboard
          </a>
        </li>
        <li>
          <a href="/admin/profile" class={Astro.url.pathname === '/admin/profile' ? 'active' : ''}>
            <span class="nav-dot"></span>Profile
          </a>
        </li>
        <li>
          <a href="/admin/projects" class={Astro.url.pathname === '/admin/projects' ? 'active' : ''}>
            <span class="nav-dot"></span>Projects
          </a>
        </li>
        <li>
          <a href="/admin/certifications" class={Astro.url.pathname === '/admin/certifications' ? 'active' : ''}>
            <span class="nav-dot"></span>Certifications
          </a>
        </li>
        <li>
          <a href="/admin/experience" class={Astro.url.pathname === '/admin/experience' ? 'active' : ''}>
            <span class="nav-dot"></span>Experience
          </a>
        </li>
        <li>
          <a href="/admin/education" class={Astro.url.pathname === '/admin/education' ? 'active' : ''}>
            <span class="nav-dot"></span>Education
          </a>
        </li>
        <li>
          <a href="/admin/skills" class={Astro.url.pathname === '/admin/skills' ? 'active' : ''}>
            <span class="nav-dot"></span>Skills
          </a>
        </li>
      </ul>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="view-site-link">
        <span>→</span> View Site
      </a>
      <a href="https://zahidabdillah.cloudflareaccess.com/cdn-cgi/access/logout" class="logout-link">
        <span>✕</span> Logout
      </a>
    </div>
  </aside>

  <main class="main-content">
    <slot />
  </main>

  <script is:inline>
    // Clock & Greeting (Asia/Jakarta, GMT+7)
    const _firstName = document.getElementById('sidebar-greeting')?.dataset.name || 'Zahid';

    function getGreeting(hour) {
      if (hour >= 5  && hour < 12) return `Good Morning, ${_firstName} 👋`;
      if (hour >= 12 && hour < 17) return `Good Afternoon, ${_firstName} 👋`;
      if (hour >= 17 && hour < 21) return `Good Evening, ${_firstName} 👋`;
      return `Good Night, ${_firstName} 🌙`;
    }

    function updateClock() {
      const now = new Date();
      const opts = { timeZone: 'Asia/Jakarta' };

      const time = now.toLocaleTimeString('id-ID', { ...opts, hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
      const timeShort = now.toLocaleTimeString('id-ID', { ...opts, hour: '2-digit', minute: '2-digit', hour12: false });
      const date = now.toLocaleDateString('id-ID', { ...opts, weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
      const hour = parseInt(now.toLocaleTimeString('en-US', { ...opts, hour: '2-digit', hour12: false }));

      const sidebarTime = document.getElementById('sidebar-clock-time');
      const sidebarDate = document.getElementById('sidebar-clock-date');
      const mobileClock = document.getElementById('mobile-clock');
      const greeting = document.getElementById('sidebar-greeting');

      if (sidebarTime) sidebarTime.textContent = time;
      if (sidebarDate) sidebarDate.textContent = date;
      if (mobileClock) mobileClock.textContent = timeShort;
      if (greeting) greeting.textContent = getGreeting(hour);
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Sidebar toggle for mobile
    window.toggleSidebar = function() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    };

    // Global toast function
    window.showToast = function(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.textContent = message;

      container.appendChild(toast);

      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(calc(100% + 1.5rem))';
        toast.style.transition = 'opacity 0.25s ease-out, transform 0.25s ease-out';
        setTimeout(() => toast.remove(), 250);
      }, 4000);
    };

    // Global helper functions for API calls
    window.api = async function(method, url, body) {
      let apiUrl = url;
      const isPagesDev = window.location.hostname.includes('pages.dev');

      if ((isPagesDev || window.location.hostname === 'localhost') && url.startsWith('/api/')) {
        apiUrl = 'https://portfolio-api.muhammadzahidabdillah.workers.dev' + url;
      }

      const options = {
        method,
        headers: {
          'Content-Type': 'application/json',
        },
      };

      if (body) {
        options.body = JSON.stringify(body);
      }

      try {
        const response = await fetch(apiUrl, options);
        const contentType = response.headers.get("content-type");

        if (contentType && contentType.indexOf("application/json") !== -1) {
          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || `Server error: ${response.status}`);
          }
          return data;
        } else {
          const text = await response.text();
          console.error('Non-JSON response received:', text.substring(0, 200));

          if (response.status === 404) {
            throw new Error("API Route not found (404). Check Cloudflare Workers mapping.");
          } else if (text.includes("Cloudflare Access")) {
            throw new Error("Blocked by Cloudflare Access. Please log in.");
          } else {
            throw new Error(`Unexpected response format (HTTP ${response.status})`);
          }
        }
      } catch (error) {
        console.error('API Error:', error);
        throw error;
      }
    };

    // Compress image before upload (max 1200px, WebP 85%)
    window.compressImage = function(file, maxWidth = 1200, quality = 0.85) {
      return new Promise((resolve) => {
        if (!file.type.startsWith('image/')) { resolve(file); return; }
        const img = new Image();
        img.onload = () => {
          let w = img.width, h = img.height;
          if (w > maxWidth) { h = Math.round(h * maxWidth / w); w = maxWidth; }
          const canvas = document.createElement('canvas');
          canvas.width = w; canvas.height = h;
          canvas.getContext('2d').drawImage(img, 0, 0, w, h);
          canvas.toBlob((blob) => {
            resolve(new File([blob], file.name.replace(/\.[^.]+$/, '.webp'), { type: 'image/webp' }));
          }, 'image/webp', quality);
        };
        img.src = URL.createObjectURL(file);
      });
    };

    // Upload file function
    window.uploadFile = async function(file, path) {
      if (file.type.startsWith('image/')) {
        file = await compressImage(file);
      }
      const formData = new FormData();
      formData.append('file', file);
      formData.append('path', path);

      try {
        const response = await fetch('/api/admin/upload', {
          method: 'POST',
          body: formData,
        });

        const contentType = response.headers.get("content-type");
        if (contentType && contentType.indexOf("application/json") !== -1) {
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.error || 'Upload failed');
          }
          return result.url;
        } else {
          throw new Error(`Upload failed with status ${response.status}`);
        }
      } catch (error) {
        console.error('Upload Error:', error);
        throw error;
      }
    };

    window.makeTableSortable = function({ tbodyId, onReorder }) {
      const tbody = document.getElementById(tbodyId);
      if (!tbody) return;

      let draggedRow = null;

      const getDragAfterElement = (container, y) => {
        const rows = [...container.querySelectorAll('tr[data-sortable="true"]:not(.dragging)')];
        return rows.reduce((closest, child) => {
          const box = child.getBoundingClientRect();
          const offset = y - box.top - box.height / 2;
          if (offset < 0 && offset > closest.offset) {
            return { offset, element: child };
          }
          return closest;
        }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
      };

      tbody.querySelectorAll('tr[data-sortable="true"]').forEach((row) => {
        row.draggable = true;

        row.addEventListener('dragstart', () => {
          draggedRow = row;
          row.classList.add('dragging');
        });

        row.addEventListener('dragend', async () => {
          row.classList.remove('dragging');
          draggedRow = null;

          const ids = [...tbody.querySelectorAll('tr[data-sortable="true"]')]
            .map((item) => Number(item.dataset.id))
            .filter((id) => Number.isInteger(id));

          if (typeof onReorder === 'function') {
            await onReorder(ids);
          }
        });
      });

      tbody.ondragover = (event) => {
        event.preventDefault();
        if (!draggedRow) return;

        const afterElement = getDragAfterElement(tbody, event.clientY);
        if (!afterElement) {
          tbody.appendChild(draggedRow);
          return;
        }

        if (afterElement !== draggedRow) {
          tbody.insertBefore(draggedRow, afterElement);
        }
      };
    };

    // Trigger deploy function
    window.triggerDeploy = async function() {
      try {
        const response = await fetch('/api/admin/deploy', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
        });

        const contentType = response.headers.get("content-type");
        if (contentType && contentType.indexOf("application/json") !== -1) {
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.error || 'Deploy failed');
          }
          return result;
        } else {
          throw new Error(`Deploy request failed with status ${response.status}`);
        }
      } catch (error) {
        console.error('Deploy Error:', error);
        throw error;
      }
    };
  </script>
</body>
</html>
